---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Stopwatch — Habit Build" description="Track your habit time with a precision stopwatch.">
  <Nav currentPage="stopwatch" />

  <main class="flex-1">
    <div class="max-w-[400px] mx-auto px-4 md:px-6 py-12 md:py-16">
      <div id="app"></div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .pulse-dot { animation: pulse-dot 1.5s ease-in-out infinite; }
</style>

<script>
  let seconds = 0;
  let interval = null;
  let running = false;
  let laps = [];
  let lastLapTime = 0;

  const STORAGE_KEY = 'habit-build-stopwatch-laps';

  function saveLaps() {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(laps)); } catch {}
  }

  function loadLaps() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) laps = JSON.parse(raw);
    } catch {}
  }

  function formatTime(totalSeconds) {
    const h = Math.floor(totalSeconds / 3600);
    const m = Math.floor((totalSeconds % 3600) / 60);
    const s = Math.floor(totalSeconds % 60);
    const cs = Math.floor((totalSeconds % 1) * 100);
    return (
      String(h).padStart(2, '0') + ':' +
      String(m).padStart(2, '0') + ':' +
      String(s).padStart(2, '0') + '<span class="text-2xl md:text-3xl font-semibold tracking-[-2.4px] text-ink">.' + String(cs).padStart(2, '0') + '</span>'
    );
  }

  function formatLapTime(totalSeconds) {
    const m = Math.floor(totalSeconds / 60);
    const s = Math.floor(totalSeconds % 60);
    const cs = Math.floor((totalSeconds % 1) * 100);
    return (
      String(m).padStart(2, '0') + ':' +
      String(s).padStart(2, '0') + '.' +
      String(cs).padStart(2, '0')
    );
  }

  function render() {
    const app = document.getElementById('app');
    if (!app) return;

    app.innerHTML = `
      <div class="text-center mb-10">
        <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h1 class="text-2xl md:text-3xl font-semibold tracking-[-1.28px] text-ink mb-2">Stopwatch</h1>
        <p class="text-sm text-body">Track your habit time with precision.</p>
      </div>

      <div class="bg-canvas rounded-md p-8" style="box-shadow: 0px 2px 2px rgba(0,0,0,0.04), 0px 8px 8px -8px rgba(0,0,0,0.04), 0 0 0 1px rgba(0,0,0,0.06) inset;">
        <div class="text-center mb-8">
          <div class="text-5xl md:text-6xl font-semibold tracking-[-2.4px] text-ink tabular-nums leading-none mb-1">
            ${formatTime(seconds)}
          </div>
          ${running ? '<span class="inline-block w-2 h-2 rounded-full bg-error pulse-dot"></span>' : ''}
        </div>

        <div class="flex items-center justify-center gap-3">
          <button id="btn-lap" class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-canvas text-ink text-sm font-medium border border-hairline transition-colors hover:bg-canvas-soft ${!running ? 'opacity-40 pointer-events-none' : ''}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </button>

          <button id="btn-startstop" class="inline-flex items-center justify-center w-20 h-20 rounded-full text-white text-lg font-medium transition-opacity hover:opacity-90 ${running ? 'bg-error' : 'bg-primary'}">
            ${running ? 'Stop' : 'Start'}
          </button>

          <button id="btn-reset" class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-canvas text-ink text-sm font-medium border border-hairline transition-colors hover:bg-canvas-soft ${running || seconds === 0 ? 'opacity-40 pointer-events-none' : ''}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 4 23 10 17 10"/>
              <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
            </svg>
          </button>
        </div>
      </div>

      <div id="laps-section" class="mt-6 ${laps.length === 0 ? 'hidden' : ''}">
        <div class="bg-canvas rounded-md" style="box-shadow: 0px 2px 2px rgba(0,0,0,0.04), 0px 8px 8px -8px rgba(0,0,0,0.04), 0 0 0 1px rgba(0,0,0,0.06) inset;">
          <div class="px-6 py-4 border-b border-hairline">
            <span class="font-mono text-xs text-mute tracking-normal uppercase">Laps</span>
          </div>
          <div class="divide-y divide-hairline max-h-64 overflow-y-auto" id="laps-list">
            ${laps.map((lap, i) => {
              const idx = laps.length - i;
              const isFastest = lap.duration === Math.min(...laps.map(l => l.duration));
              const isSlowest = lap.duration === Math.max(...laps.map(l => l.duration));
              let color = 'text-ink';
              if (laps.length > 2) {
                if (isFastest) color = 'text-success';
                else if (isSlowest) color = 'text-mute';
              }
              return `
                <div class="flex items-center justify-between px-6 py-3">
                  <span class="text-sm text-body">Lap ${idx}</span>
                  <span class="text-sm font-medium tabular-nums ${color}">${formatLapTime(lap.duration)}</span>
                </div>
              `;
            }).join('')}
          </div>
        </div>
      </div>
    `;

    document.getElementById('btn-startstop')?.addEventListener('click', toggleStartStop);
    document.getElementById('btn-lap')?.addEventListener('click', recordLap);
    document.getElementById('btn-reset')?.addEventListener('click', resetStopwatch);
  }

  function toggleStartStop() {
    if (running) {
      stop();
    } else {
      start();
    }
  }

  function start() {
    if (interval) return;
    running = true;
    const startTime = performance.now() - seconds * 1000;
    interval = setInterval(() => {
      seconds = (performance.now() - startTime) / 1000;
      render();
    }, 20);
    render();
  }

  function stop() {
    if (interval) {
      clearInterval(interval);
      interval = null;
    }
    running = false;
    render();
  }

  function recordLap() {
    if (!running) return;
    const lapDuration = seconds - lastLapTime;
    laps.push({ time: seconds, duration: lapDuration });
    lastLapTime = seconds;
    saveLaps();
    render();
  }

  function resetStopwatch() {
    if (running) return;
    if (interval) {
      clearInterval(interval);
      interval = null;
    }
    seconds = 0;
    lastLapTime = 0;
    laps = [];
    saveLaps();
    render();
  }

  loadLaps();
  render();
</script>
