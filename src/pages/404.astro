---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found — Habit Build" description="The page you're looking for doesn't exist.">
  <Nav currentPage="home" />

  <main class="flex-1">
    <div class="max-w-[600px] mx-auto px-4 md:px-6 py-24 md:py-32 text-center">
      <p class="font-mono text-6xl md:text-8xl font-semibold tracking-[-2.4px] text-ink mb-4">404</p>
      <h1 class="text-xl md:text-2xl font-semibold tracking-[-0.96px] text-ink mb-3">Page not found</h1>
      <p class="text-sm text-body mb-8 max-w-sm mx-auto">The page you're looking for doesn't exist or has been moved.</p>
      <div class="flex items-center justify-center gap-3">
        <a href="/" class="inline-flex items-center h-10 px-5 bg-primary text-on-primary text-sm font-medium rounded-[100px] no-underline transition-opacity hover:opacity-90">Go Home</a>
        <a href="/plan" class="inline-flex items-center h-10 px-5 bg-canvas text-ink text-sm font-medium rounded-[100px] no-underline border border-hairline transition-colors hover:bg-canvas-soft">Go to Plan</a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
