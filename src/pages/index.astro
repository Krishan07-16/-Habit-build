---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav currentPage="home" />

  <main>
    <!-- Hero -->
    <section class="relative bg-canvas overflow-hidden">
      <div class="absolute inset-0 opacity-60" aria-hidden="true">
        <div class="absolute inset-0" style="
          background:
            radial-gradient(ellipse 80% 60% at 50% -20%, rgba(0,124,240,0.3) 0%, transparent 60%),
            radial-gradient(ellipse 60% 50% at 80% 40%, rgba(121,40,202,0.2) 0%, transparent 50%),
            radial-gradient(ellipse 60% 50% at 20% 60%, rgba(0,223,216,0.15) 0%, transparent 50%);
        "></div>
      </div>

      <div class="relative max-w-[1400px] mx-auto px-4 md:px-6 pt-24 pb-32 md:pt-32 md:pb-48">
        <div class="max-w-2xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-semibold leading-tight tracking-[-2.4px] text-ink mb-4">
            Build habits that stick.
          </h1>
          <p class="text-lg md:text-xl text-body leading-relaxed mb-6 max-w-lg mx-auto">
            A gentle, sustainable approach to building habits. No streaks, no shame. Just consistency.
          </p>
          <p class="text-base text-body/60 mb-8 italic">"I can't make myself start."</p>
          <div class="flex items-center justify-center gap-3">
            <a
              href="/assessment"
              class="inline-flex items-center h-12 px-6 bg-primary text-on-primary text-base font-medium rounded-[100px] no-underline transition-opacity hover:opacity-90"
            >Start with 5 minutes</a>
            <a
              href="#how-it-works"
              class="inline-flex items-center h-12 px-6 bg-canvas text-ink text-base font-medium rounded-[100px] no-underline border border-hairline transition-colors hover:bg-canvas-soft"
            >How It Works</a>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section id="how-it-works" class="bg-canvas-soft py-24 md:py-32">
      <div class="max-w-[1400px] mx-auto px-4 md:px-6">
        <div class="text-center mb-16">
          <span class="font-mono text-xs text-mute tracking-normal uppercase">How It Works</span>
          <h2 class="text-3xl md:text-4xl font-semibold leading-tight tracking-[-1.28px] text-ink mt-3 mb-4">
            Four steps to consistency.
          </h2>
        </div>

        <div class="grid md:grid-cols-4 gap-4">
          <div class="text-center">
            <div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center mx-auto mb-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><polyline points="9 14 11 16 15 12"/></svg>
          </div>
            <h3 class="text-sm font-semibold text-ink mb-1">Assessment</h3>
            <p class="text-xs text-body">Answer 7 questions about your habit, obstacles, and goals.</p>
          </div>
          <div class="text-center">
            <div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center mx-auto mb-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
            <h3 class="text-sm font-semibold text-ink mb-1">Your Plan</h3>
            <p class="text-xs text-body">Get a personalized 30-day plan with minimum, target, and maximum.</p>
          </div>
          <div class="text-center">
            <div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center mx-auto mb-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
            <h3 class="text-sm font-semibold text-ink mb-1">Show Up</h3>
            <p class="text-xs text-body">Use the resistance timer. Just 5 minutes. Then you can stop.</p>
          </div>
          <div class="text-center">
            <div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center mx-auto mb-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          </div>
            <h3 class="text-sm font-semibold text-ink mb-1">Track Progress</h3>
            <p class="text-xs text-body">See your consistency grow. Your plan adapts to your life.</p>
          </div>
        </div>

        <div class="flex items-center justify-center mt-12">
          <div class="hidden md:flex items-center gap-2 text-hairline-strong">
            <div class="w-8 h-px bg-hairline-strong"></div>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            <div class="w-8 h-px bg-hairline-strong"></div>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            <div class="w-8 h-px bg-hairline-strong"></div>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
        </div>
      </div>
    </section>

    <!-- Philosophy -->
    <section class="bg-canvas py-24 md:py-32">
      <div class="max-w-[1400px] mx-auto px-4 md:px-6">
        <div class="text-center mb-16">
          <span class="font-mono text-xs text-mute tracking-normal uppercase">Philosophy</span>
          <h2 class="text-3xl md:text-4xl font-semibold leading-tight tracking-[-1.28px] text-ink mt-3 mb-4">
            Consistency over intensity.
          </h2>
          <p class="text-body text-base md:text-lg max-w-lg mx-auto">
            The goal is not to maximize productivity. The goal is to help you maintain habits over long periods.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-4">
          <article class="bg-canvas rounded-md p-6" style="box-shadow: 0px 2px 2px rgba(0,0,0,0.04), 0px 8px 8px -8px rgba(0,0,0,0.04), 0 0 0 1px rgba(0,0,0,0.06) inset;">
            <div class="w-10 h-10 rounded-full bg-canvas-soft-2 flex items-center justify-center mb-4">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="10" cy="10" r="8"/><path d="M10 6v4l3 3"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold tracking-[-0.6px] text-ink mb-2">Time Invested</h3>
            <p class="text-sm text-body leading-relaxed">We track time spent on your habit, not tasks completed. Progress is measured in minutes, not checkboxes.</p>
          </article>

          <article class="bg-canvas rounded-md p-6" style="box-shadow: 0px 2px 2px rgba(0,0,0,0.04), 0px 8px 8px -8px rgba(0,0,0,0.04), 0 0 0 1px rgba(0,0,0,0.06) inset;">
            <div class="w-10 h-10 rounded-full bg-canvas-soft-2 flex items-center justify-center mb-4">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 18L10 2l8 16H2z"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold tracking-[-0.6px] text-ink mb-2">Consistency, Not Intensity</h3>
            <p class="text-sm text-body leading-relaxed">Small steps done daily beat huge efforts done once. We help you show up, even when it is hard.</p>
          </article>

          <article class="bg-canvas rounded-md p-6" style="box-shadow: 0px 2px 2px rgba(0,0,0,0.04), 0px 8px 8px -8px rgba(0,0,0,0.04), 0 0 0 1px rgba(0,0,0,0.06) inset;">
            <div class="w-10 h-10 rounded-full bg-canvas-soft-2 flex items-center justify-center mb-4">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="4 14 8 10 12 14 16 6"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold tracking-[-0.6px] text-ink mb-2">Sustainable Growth</h3>
            <p class="text-sm text-body leading-relaxed">Your plan adapts to your life. Consistent success means gradual increases. Setbacks are met with support, not punishment.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-primary py-24 md:py-32">
      <div class="max-w-[1400px] mx-auto px-4 md:px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-semibold leading-tight tracking-[-1.28px] text-on-primary mb-4">
          Ready to build your habit?
        </h2>
        <p class="text-base md:text-lg text-white/70 max-w-md mx-auto mb-10">
          Building a new habit doesn't have to be hard. Get a 30-day plan in 2 minutes.
        </p>
        <a
          href="/assessment"
          class="inline-flex items-center h-12 px-8 bg-on-primary text-primary text-base font-medium rounded-[100px] no-underline transition-opacity hover:opacity-90"
        >Start with 5 minutes</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
