---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Your Plan — Habit Build" description="Your personalized 30-day consistency plan.">
  <Nav currentPage="plan" />

  <main class="flex-1">
    <div class="max-w-[600px] mx-auto px-4 md:px-6 py-12 md:py-16">
      <div id="app">
        <div class="space-y-4 animate-pulse">
          <div class="text-center"><div class="h-3 w-20 bg-canvas-subtle rounded mx-auto mb-3"></div><div class="h-6 w-48 bg-canvas-subtle rounded mx-auto mb-2"></div><div class="h-4 w-32 bg-canvas-subtle rounded mx-auto"></div></div>
          <div class="bg-canvas rounded-md p-6 border border-hairline"><div class="flex items-center gap-6"><div class="w-24 h-24 bg-canvas-subtle rounded-full shrink-0"></div><div class="flex-1 space-y-2"><div class="h-3 w-12 bg-canvas-subtle rounded"></div><div class="h-5 w-32 bg-canvas-subtle rounded"></div><div class="h-3 w-48 bg-canvas-subtle rounded"></div></div></div></div>
          <div class="bg-canvas rounded-md p-6 border border-hairline"><div class="h-3 w-24 bg-canvas-subtle rounded mb-4"></div><div class="h-48 bg-canvas-subtle rounded"></div></div>
          <div class="bg-canvas rounded-md p-6 border border-hairline"><div class="h-3 w-24 bg-canvas-subtle rounded mb-4"></div><div class="h-48 bg-canvas-subtle rounded"></div></div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .pulse-dot { animation: pulse-dot 1.5s ease-in-out infinite; }
  @keyframes sparkle-fade {
    0% { opacity: 1; transform: translate(0,0) scale(1); }
    100% { opacity: 0; transform: translate(var(--dx),var(--dy)) scale(0); }
  }
  .sparkle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-primary);
    pointer-events: none;
    animation: sparkle-fade 1s ease-out forwards;
  }
  @keyframes ring-scale {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }
  .ring-scale { animation: ring-scale 0.5s ease-out; }
  #focus-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(250,247,242,0.92);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .dark #focus-overlay {
    background: rgba(26,24,22,0.92);
  }
  #focus-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  #focus-overlay .focus-exit {
    position: fixed;
    top: 16px;
    right: 20px;
    font-size: 13px;
    color: var(--color-mute);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 100px;
    transition: color 0.15s, background 0.15s;
  }
  #focus-overlay .focus-exit:hover {
    color: var(--color-ink);
    background: var(--color-hairline);
  }
  #task-switch-panel {
    transition: opacity 0.2s, transform 0.2s;
  }
  #app { transition: opacity 0.3s ease; }
  .timer-action-btn {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }
  .dark .timer-action-btn {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }
</style>

<script>
  import { escapeHtml, getSavedPlan, savePlan, getAssessmentAnswers, clearAssessment, getSavedCheckIns, saveCheckIns, savePreviousPlan, savePreviousCheckIns, getPreviousPlan, getPreviousCheckIns, getAdjustments, getCurrentDay, isPlanComplete, hasThreeDayStreak, computeWeeklyRamp, buildExplanation, generatePlan as genPlan, getTodayString, getDateString, getFeedback, saveCheckInMinutes } from '../lib/utils.js';
  import { timerState, getSavedTimerDuration, saveTimerDuration, getTodayResistanceSets, incrementResistanceSets, getTodayResistanceMinutes, addTodayResistanceMinutes, formatTimer, saveTimerState, clearTimerState, restoreTimerState } from '../lib/timer.js';
  import { stopwatchState, formatStopwatch, saveStopwatchSession, saveStopwatchState, clearStopwatchState, restoreStopwatchState } from '../lib/stopwatch.js';
  import { showFocusMode, updateFocusMode, hideFocusMode } from '../lib/focus-mode.js';
  import { playChime, spawnSparkles } from '../lib/sparkle.js';
  import { evaluateAdjustment, calculateAdaptedTarget, getPlanStats } from '../lib/adjustments.js';
  import { renderTaskSwitchPanel, dismissTaskSwitchPanel, refreshTaskSuggestion } from '../lib/task-switch.js';

  let currentTool = 'timer';
  let currentPhase = 1;
  let planRef = null;

  function exitFocusMode(plan) {
    if (stopwatchState.status === 'running') {
      if (stopwatchState.interval) { clearInterval(stopwatchState.interval); stopwatchState.interval = null; }
      stopwatchState.status = 'stopped';
      clearStopwatchState();
    } else if (stopwatchState.status === 'paused') {
      if (stopwatchState.interval) { clearInterval(stopwatchState.interval); stopwatchState.interval = null; }
    } else if (timerState.status === 'running') {
      if (timerState.interval) { clearInterval(timerState.interval); timerState.interval = null; }
      var savedDuration = 300;
      var elapsedSeconds = savedDuration - timerState.seconds;
      if (typeof posthog !== 'undefined') posthog.capture('timer_abandoned', { elapsed_seconds: elapsedSeconds });
      clearTimerState();
      timerState.seconds = savedDuration;
      timerState.earlyExit = true;
      incrementResistanceSets();
      if (elapsedSeconds > 0) addTodayResistanceMinutes(Math.round(elapsedSeconds / 60));
      timerState.status = 'idle';
    } else if (timerState.status === 'paused') {
      if (timerState.interval) { clearInterval(timerState.interval); timerState.interval = null; }
    }
    hideFocusMode();
    renderActionTools(plan);
    renderSessionIndicator();
  }

  function renderPlanGuide(plan) {
    var bullets = Array.isArray(plan.explanation) ? plan.explanation : [plan.explanation];
    var t = Math.min(1, Math.max(0, (plan.target - plan.minimum) / (plan.maximum - plan.minimum || 1)));
    var x0 = 4, x1 = 80, x2 = 156, y0 = 50, y1 = 6, y2 = 50;
    var dotX = (1-t)*(1-t)*x0 + 2*(1-t)*t*x1 + t*t*x2;
    var dotY = (1-t)*(1-t)*y0 + 2*(1-t)*t*y1 + t*t*y2;
    var pct = Math.round(t * 100);

    var bulletHtml = '';
    for (var bi = 0; bi < bullets.length; bi++) {
      bulletHtml += "<li class=\"text-sm text-body leading-relaxed pl-4 relative before:content-[''] before:absolute before:left-0 before:top-2.5 before:w-1.5 before:h-1.5 before:rounded-full before:bg-ink/30\">" + escapeHtml(bullets[bi]) + '</li>';
    }

    var timeSlotHtml = '';
    if (plan.timeSlot && plan.timeSlot !== 'No preference') {
      timeSlotHtml = '<div class="text-sm text-body pt-1"><span class="font-medium text-ink">Best time:</span> ' + escapeHtml(plan.timeSlot) + '</div>';
    }

    return '<div id="plan-guide" class="py-2 space-y-3">'
      + '<ul id="plan-bullets" class="space-y-1.5">' + bulletHtml + '</ul>'
      + timeSlotHtml
      + '<div class="pt-2 flex justify-center">'
      + '<svg width="160" height="56" viewBox="0 0 160 56" fill="none" class="text-mute">'
      + '<path d="M4 50 Q80 6 156 50" class="stroke-hairline" stroke-width="2" stroke-linecap="round" fill="none"/>'
      + '<path d="M4 50 Q80 6 156 50" class="stroke-ink" stroke-width="2" stroke-linecap="round" fill="none" stroke-dasharray="200" stroke-dashoffset="' + (200 - 200 * pct / 100) + '" style="transition:stroke-dashoffset 0.5s"/>'
      + '<circle cx="' + dotX.toFixed(1) + '" cy="' + dotY.toFixed(1) + '" r="4" fill="var(--color-ink)" stroke="white" stroke-width="1.5"/>'
      + '<text x="' + x0 + '" y="54" class="text-[9px]" fill="var(--color-mute)" text-anchor="middle">' + plan.minimum + '</text>'
      + '<text x="' + x2 + '" y="54" class="text-[9px]" fill="var(--color-mute)" text-anchor="middle">' + plan.maximum + '</text>'
      + '<text x="' + dotX.toFixed(1) + '" y="0" class="text-[9px]" fill="var(--color-ink)" text-anchor="middle" font-weight="500">Target ' + plan.target + '</text>'
      + '</svg>'
      + '</div>'
      + '</div>';
  }

  function renderWeeklyRampCard(plan) {
    if (!Array.isArray(plan.weeklyRamp) || plan.weeklyRamp.length !== 4) return '';
    var currentDay = getCurrentDay(plan.startDate);
    var currentWeek = Math.min(4, Math.ceil(currentDay / 7));
    var weekLabels = ['Week 1', 'Week 2', 'Week 3', 'Week 4'];
    var weekHtml = '';
    for (var wi = 0; wi < 4; wi++) {
      var isActive = wi + 1 === currentWeek;
      var isPast = wi + 1 < currentWeek;
      weekHtml += '<div class="flex-1 text-center' + (isPast ? ' opacity-40' : '') + '">';
      weekHtml += '<div class="text-sm text-ink font-semibold">' + plan.weeklyRamp[wi] + 'm</div>';
      weekHtml += '<div class="text-[10px] text-mute mt-0.5">' + weekLabels[wi] + '</div>';
      if (isActive) weekHtml += '<div class="w-full h-0.5 bg-primary mt-1.5 rounded-full"></div>';
      weekHtml += '</div>';
    }
    return '<div class="bg-canvas rounded-md p-4 mb-5 border border-hairline"><div class="text-[10px] text-mute mb-2 text-center">Weekly ramp</div><div class="flex items-center gap-2">' + weekHtml + '</div></div>';
  }

  function renderPlan(plan) {
    planRef = plan;
    const app = document.getElementById('app');
    if (!app) return;
    app.style.opacity = '0';

    if (isPlanComplete(plan)) { renderCompletionSummary(plan); return; }

    var continuing = plan.status === 'continuing';
    var day = continuing ? 3 : getCurrentDay(plan.startDate);
    currentPhase = Math.min(day, 3);

    var checkIns = getSavedCheckIns();
    var todayStr = getTodayString();
    var todayEntry = checkIns[todayStr] || null;
    var todaySets = getTodayResistanceSets();
    var todayResMin = getTodayResistanceMinutes();
    var isFirstDay = day === 1 && !todayEntry;

    var weeklyReviewAreaHtml = '';
    var todayDate = new Date(); todayDate.setHours(0, 0, 0, 0);
    if (todayDate.getDay() === 0 && Object.keys(checkIns).length > 0) {
      var weekStart = new Date(todayDate);
      weekStart.setDate(todayDate.getDate() - todayDate.getDay() + (todayDate.getDay() === 0 ? -6 : 1));
      var weekKey = 'habit-build-weekly-review-' + getDateString(weekStart);
      try { if (localStorage.getItem(weekKey) === null) weeklyReviewAreaHtml = '<div id="weekly-review-area" class="bg-canvas-soft rounded-md p-5 mb-5"><p class="text-sm text-body leading-relaxed mb-3 font-medium">Weekly check-in: How did this week feel?</p><div class="flex gap-2"><button data-review="great" class="review-btn-plan inline-flex items-center h-8 px-3 bg-canvas text-ink text-xs font-medium rounded-full no-underline border border-hairline transition-colors hover:bg-canvas-soft">Great</button><button data-review="okay" class="review-btn-plan inline-flex items-center h-8 px-3 bg-canvas text-ink text-xs font-medium rounded-full no-underline border border-hairline transition-colors hover:bg-canvas-soft">Okay</button><button data-review="hard" class="review-btn-plan inline-flex items-center h-8 px-3 bg-canvas text-ink text-xs font-medium rounded-full no-underline border border-hairline transition-colors hover:bg-canvas-soft">Hard</button></div></div>'; } catch {}
    }

    app.innerHTML = '<div id="focus-overlay"><a href="#" id="focus-exit" class="focus-exit">Leave session</a><div id="focus-content" class="text-center"></div></div>'
      + '<div class="text-center mb-4">'
      + (continuing ? '' : '<p class="text-xs text-mute mb-1">Day ' + day + ' of 30</p>')
      + '<h1 class="text-xl md:text-2xl font-semibold  text-ink">' + escapeHtml(plan.habit) + '</h1>'
      + '<p class="text-sm text-body mt-1">' + escapeHtml(plan.goal) + '</p>'
      + '</div>'
      + '<div class="bg-link-bg-soft rounded-lg px-5 py-4 mb-4"><div class="flex items-start gap-3"><div class="w-8 h-8 bg-link/10 rounded-full flex items-center justify-center shrink-0 mt-0.5"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><div><p class="text-base text-link-deep font-semibold">Your minimum today: ' + plan.minimum + ' min. That\'s enough.</p><p class="text-sm text-link-deep/80 mt-1">Showing up is the win. Your habit stays alive.</p></div></div></div>'
      + (!todayEntry && todaySets === 0 ? '<div class="bg-warning-soft rounded-lg px-4 py-4 mb-4 border-l-4 border-warning"><div class="flex items-start gap-3"><div class="w-7 h-7 bg-warning/10 rounded-full flex items-center justify-center shrink-0 mt-0.5"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ab570a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg></div><div><p class="text-sm font-semibold text-warning-deep">Having a hard day?</p><p class="text-sm text-body mt-1">Do ' + plan.minimum + ' minutes. That\'s your minimum. That\'s a win.</p></div></div></div>' : '')
      + '<div id="action-tools" class="mb-5"></div>'
      + (!continuing && !todayEntry ? '<div class="bg-warning-soft rounded-lg px-4 py-4 mb-5 border-l-4 border-warning"><p class="text-sm font-semibold text-warning-deep">First, then reward.</p><p class="text-sm text-body mt-1">Do your habit before the activity you look forward to.</p></div>' : '')
      + renderWeeklyRampCard(plan)
      + weeklyReviewAreaHtml
      + (day <= 7 && !todayEntry ? '<div class="bg-canvas-soft rounded-lg px-4 py-3 mb-4 text-center border border-hairline"><p class="text-sm text-body font-medium">Week 1: Just sit. That\'s the goal.</p><p class="text-xs text-mute mt-1">The hardest part is starting. Every day you open this page, you\'re winning.</p></div>' : '')
      + '<div id="session-indicator" class="mb-4"></div>'

      + '<div id="task-switch-area" class="mt-2 mb-4"></div>'
      + '<details class="group mt-2"><summary class="flex items-center gap-2 cursor-pointer text-sm text-mute font-medium hover:text-ink transition-colors"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-90 transition-transform"><polyline points="9 18 15 12 9 6"/></svg>Stopwatch</summary><div class="mt-3" id="stopwatch-collapsed"></div></details>'
      + '<details class="group mt-2"><summary class="flex items-center gap-2 cursor-pointer text-sm text-mute font-medium hover:text-ink transition-colors"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-90 transition-transform"><polyline points="9 18 15 12 9 6"/></svg>Your Plan</summary><div class="bg-canvas rounded-md p-5 md:p-6 space-y-4 mt-3 border border-hairline"><div class="grid grid-cols-3 gap-3 py-2 border-b border-hairline"><div class="text-center"><div id="plan-target-value" class="text-xl font-semibold  text-ink">' + plan.target + '</div><div class="text-xs text-mute mt-1">Target</div></div><div class="text-center"><div id="plan-minimum-value" class="text-xl font-semibold  text-ink">' + plan.minimum + '</div><div class="text-xs text-mute mt-1">Minimum</div></div><div class="text-center"><div id="plan-maximum-value" class="text-xl font-semibold  text-ink">' + plan.maximum + '</div><div class="text-xs text-mute mt-1">Maximum</div></div></div>' + renderPlanGuide(plan) + '</div></details>'
      + '<details class="group mt-2"><summary class="flex items-center gap-2 cursor-pointer text-sm text-mute font-medium hover:text-ink transition-colors"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-90 transition-transform"><polyline points="9 18 15 12 9 6"/></svg>Plan History</summary><div class="mt-3" id="adjustment-history"></div></details>'
      + '<div class="flex items-center justify-center mt-6 gap-3"><a href="/progress" class="inline-flex items-center h-10 px-4 bg-canvas text-ink text-sm font-medium rounded-full no-underline border border-hairline transition-colors hover:bg-canvas-soft">View Progress</a><button id="btn-share" class="inline-flex items-center h-10 px-4 bg-canvas text-ink text-sm font-medium rounded-full no-underline border border-hairline transition-colors hover:bg-canvas-soft">Share Today\'s Progress</button><button id="btn-restart" class="inline-flex items-center h-10 px-4 bg-canvas text-ink text-sm font-medium rounded-full no-underline border border-hairline transition-colors hover:bg-canvas-soft">Retake Assessment</button></div>'
      + '<div id="checkin-section" class="mb-5 mt-8"></div>';

    requestAnimationFrame(function () { app.style.opacity = '1'; });

    document.getElementById('btn-share')?.addEventListener('click', function () {
      var text = 'Habit Build \u2014 Day ' + day + ': ' + escapeHtml(plan.habit) + '\n';
      text += todayResMin > 0 ? todayResMin + ' min resistance' : 'Ready to start';
      text += todaySets > 0 ? ' \u00B7 ' + todaySets + ' sets' : '';
      text += '\nTarget: ' + plan.target + ' min \u00B7 Minimum: ' + plan.minimum + ' min';
      if (navigator.share) {
        navigator.share({ title: 'Habit Build', text: text }).catch(function () {});
      } else {
        try { navigator.clipboard.writeText(text); } catch {}
        var btn = document.getElementById('btn-share');
        if (btn) { btn.textContent = 'Copied!'; setTimeout(function () { btn.textContent = 'Share Today\'s Progress'; }, 2000); }
      }
    });

    document.getElementById('btn-restart')?.addEventListener('click', function () {
      var curPlan = getSavedPlan();
      if (curPlan && curPlan.habit) {
        savePreviousPlan(curPlan);
        savePreviousCheckIns(getSavedCheckIns());
      }
      clearAssessment();
      try { localStorage.removeItem('habit-build-plan'); } catch {}
      window.location.href = '/assessment';
    });

    var exitBtn = document.getElementById('focus-exit');
    if (exitBtn) {
      exitBtn.onclick = function (e) { e.preventDefault(); exitFocusMode(plan); };
    }

    renderActionTools(plan);
    renderCheckIn(plan);
    renderAdjustmentHistory();
    renderSessionIndicator();
    renderCollapsedStopwatch(plan);
    kickstartStopwatch(plan);
    kickstartTimer(plan);

    document.querySelectorAll('.review-btn-plan').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var val = btn.getAttribute('data-review');
        var now = new Date(); now.setHours(0, 0, 0, 0);
        var ws = new Date(now);
        ws.setDate(now.getDate() - now.getDay() + (now.getDay() === 0 ? -6 : 1));
        var wkKey = 'habit-build-weekly-review-' + getDateString(ws);
        try { localStorage.setItem(wkKey, JSON.stringify({ rating: val, note: '', date: getTodayString() })); } catch {}
        document.querySelectorAll('.review-btn-plan').forEach(function (b) {
          b.classList.remove('bg-primary', 'text-on-primary', 'border-primary');
        });
        btn.classList.add('bg-primary', 'text-on-primary', 'border-primary');
        var wrArea = document.getElementById('weekly-review-area');
        if (wrArea) { wrArea.style.transition = 'opacity 0.3s'; wrArea.style.opacity = '0.5'; }
      });
    });

    try { localStorage.setItem('habit-build-plan-viewed', 'true'); } catch {}
  }

  function renderError(message) {
    var app = document.getElementById('app');
    if (!app) return;
    app.innerHTML = '<div class="text-center mb-10"><div class="w-12 h-12 bg-error-soft rounded-full flex items-center justify-center mx-auto mb-4"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ee0000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div><h1 class="text-2xl md:text-3xl font-semibold  text-ink mb-2">Something went wrong</h1><p class="text-sm text-body mb-6">' + escapeHtml(message) + '</p><a href="/assessment" class="inline-flex items-center h-12 px-6 bg-primary text-on-primary text-base font-medium rounded-full no-underline transition-opacity hover:opacity-90">Take the Assessment</a></div>';
  }

  function updatePlanDisplay(plan) {
    var targetEl = document.getElementById('plan-target-value');
    var minEl = document.getElementById('plan-minimum-value');
    var maxEl = document.getElementById('plan-maximum-value');
    var guideEl = document.getElementById('plan-guide');
    if (targetEl) targetEl.textContent = plan.target;
    if (minEl) minEl.textContent = plan.minimum;
    if (maxEl) maxEl.textContent = plan.maximum;
    if (guideEl) { guideEl.outerHTML = renderPlanGuide(plan); }
  }

  function renderAdjustmentHistory() {
    var section = document.getElementById('adjustment-history');
    if (!section) return;
    var adjustments = getAdjustments();
    if (adjustments.length === 0) return;
    var rows = '';
    for (var i = adjustments.length - 1; i >= 0; i--) {
      var adj = adjustments[i];
      var d = new Date(adj.date + 'T00:00:00');
      var month = d.toLocaleString('en-US', { month: 'short' });
      var dayNum = d.getDate();
      var arrow = adj.direction === 'increased' ? '\u2191' : '\u2193';
      var color = adj.direction === 'increased' ? 'text-success' : 'text-mute';
      rows += '<div class="flex items-center justify-between py-2 border-b border-hairline last:border-b-0"><span class="text-sm text-body">' + month + ' ' + dayNum + '</span><span class="text-sm text-ink font-medium ' + color + '">' + adj.previousTarget + ' ' + arrow + ' ' + adj.newTarget + ' min</span></div>';
    }
    section.innerHTML = '<div class="bg-canvas rounded-md p-6 md:p-8 space-y-4 mt-6 border border-hairline"><h2 class="text-lg font-semibold  text-ink">Plan Adjustments</h2><p class="text-sm text-body">Your targets are adjusted based on your performance. Showing the ' + adjustments.length + ' most recent adjustment' + (adjustments.length > 1 ? 's' : '') + '.</p>' + rows + '</div>';
  }

  function handleStartNewPlan(plan) {
    var adaptedTarget = calculateAdaptedTarget();
    var newTarget = adaptedTarget || plan.target;
    var newMin = Math.max(3, Math.round(newTarget * 0.5));
    var newMax = Math.round(newTarget * 1.5);
    var newPlan = {
      habit: plan.habit, goal: plan.goal, target: newTarget, minimum: newMin, maximum: newMax,
      explanation: ['For ' + escapeHtml(plan.habit) + ': Aim for ' + newTarget + ' min/day.', newMin < newTarget ? 'On hard days, do ' + newMin + ' min.' : null, 'Max ' + newMax + ' min to avoid burnout.'].filter(Boolean),
      startDate: new Date().toISOString(),
    };
    savePlan(newPlan);
    if (typeof posthog !== 'undefined') posthog.capture('plan_generated', { habit: newPlan.habit, target: newPlan.target, minimum: newPlan.minimum, maximum: newPlan.maximum });
    renderPlan(newPlan);
  }

  function handleContinueFreely(plan) {
    plan.status = 'continuing';
    savePlan(plan);
    renderPlan(plan);
  }

  function renderCompletionSummary(plan) {
    var app = document.getElementById('app');
    if (!app) return;
    if (typeof posthog !== 'undefined') posthog.capture('plan_completed');
    var stats = getPlanStats();
    var trendSymbol = stats.trendPct > 0 ? '+' : '';
    var trendColor = stats.trendPct > 5 ? 'text-success' : stats.trendPct < -5 ? 'text-mute' : 'text-ink';

    var reflections = [
      'What surprised you about this journey?',
      'What was your hardest day, and how did you get through it?',
      'What would you tell someone starting their first 30 days?',
      'What did you learn about yourself?',
      'What will you carry forward from this experience?',
    ];
    var randomReflection = reflections[Math.floor(Math.random() * reflections.length)];

