    if (gapDays > 0) {
      if (typeof posthog !== 'undefined') posthog.capture('gap_return', { gap_days: gapDays });
      html += '<div class="bg-link-bg-soft rounded-lg px-5 py-4 text-center"><div class="flex items-center justify-center gap-2"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><p class="text-sm font-semibold text-link leading-relaxed">You came back. That\'s a win. The habit is still alive.</p></div></div>';
      var gapFeedbackKey = 'habit-build-gap-feedback-' + todayStr;
      var hasGivenFeedback = false;
      try { hasGivenFeedback = localStorage.getItem(gapFeedbackKey) !== null; } catch {}
      if (!hasGivenFeedback) {
        html += '<div id="gap-feedback" class="bg-canvas-soft rounded-md p-4 mt-4 text-center"><p class="text-sm text-body mb-3">What almost stopped you from coming back?</p><div class="flex flex-wrap justify-center gap-2 mb-3"><button data-reason="forgot" class="gap-reason-btn inline-flex items-center h-8 px-3 bg-canvas text-ink text-xs font-medium rounded-full border border-hairline transition-colors hover:bg-canvas-soft">I forgot</button><button data-reason="too-busy" class="gap-reason-btn inline-flex items-center h-8 px-3 bg-canvas text-ink text-xs font-medium rounded-full border border-hairline transition-colors hover:bg-canvas-soft">Too busy</button><button data-reason="no-motivation" class="gap-reason-btn inline-flex items-center h-8 px-3 bg-canvas text-ink text-xs font-medium rounded-full border border-hairline transition-colors hover:bg-canvas-soft">No motivation</button><button data-reason="overwhelmed" class="gap-reason-btn inline-flex items-center h-8 px-3 bg-canvas text-ink text-xs font-medium rounded-full border border-hairline transition-colors hover:bg-canvas-soft">Felt overwhelmed</button><button data-reason="other" class="gap-reason-btn inline-flex items-center h-8 px-3 bg-canvas text-ink text-xs font-medium rounded-full border border-hairline transition-colors hover:bg-canvas-soft">Other</button></div><p class="text-[10px] text-mute">This helps me improve Habit Build.</p></div>';
      }
    } else if (yesterdayMissed) {
      if (hasStreak) {
        html += '<div class="bg-canvas rounded-md p-4 text-center border border-hairline"><p class="text-sm text-success font-medium">&#10003; You\'re back on track.</p></div>';
      } else {
        html += '<div class="bg-canvas rounded-md p-4 border border-hairline"><p class="text-sm text-body leading-relaxed mb-3">Building consistency is hard for everyone. Missed yesterday? That\'s normal. Here\'s today\'s target: <strong>' + plan.target + ' min</strong>. The resistance timer is ready if you need it.</p><button id="btn-start-timer-recovery" class="inline-flex items-center h-9 px-4 bg-primary text-on-primary text-sm font-medium rounded-full no-underline transition-opacity hover:opacity-90">Start Timer</button></div>';
      }
    }

    var swMinutes = Math.floor(stopwatchState.seconds / 60);
    var savedMinutes = todayEntry ? todayEntry.actualMinutes : 0;
    var totalToday = savedMinutes + swMinutes;
    var todayTarget = todayEntry ? todayEntry.target : plan.target;
    var ratio = Math.min(1, totalToday / todayTarget);
    var achieved = totalToday >= todayTarget;

    var isFirstSession = !todayEntry && totalToday === 0 && daysSinceStart <= 1;

    if (isFirstSession) {
      html += '<div class="bg-canvas rounded-md p-6 md:p-8 text-center border border-hairline"><div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="stroke-ink" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10M18 20V4M6 20v-4"/></svg></div><p class="text-lg font-semibold  text-ink mb-1">Your first rep awaits.</p><p class="text-sm text-body">Start the resistance timer above. Just 5 minutes.</p></div>';
    } else {
      var r = 40, circ = 2 * Math.PI * r, offset = circ * (1 - ratio);
      html += '<div class="bg-canvas rounded-md p-6 md:p-8 border border-hairline"><div class="flex items-center gap-6"><div class="relative shrink-0"><svg width="96" height="96" viewBox="0 0 96 96"><circle cx="48" cy="48" r="' + r + '" fill="none" class="stroke-hairline" stroke-width="6"/><circle cx="48" cy="48" r="' + r + '" fill="none" class="' + (achieved ? 'stroke-link' : 'stroke-ink') + '" stroke-width="6" stroke-dasharray="' + circ + '" stroke-dashoffset="' + offset + '" stroke-linecap="round" transform="rotate(-90 48 48)" style="transition: stroke-dashoffset 0.5s"/></svg><div class="absolute inset-0 flex items-center justify-center"><span class="text-lg font-semibold text-ink tabular-nums">' + Math.round(ratio * 100) + '%</span></div></div><div class="flex-1 min-w-0 space-y-1"><p class="text-xs text-mute">Today</p><p class="text-xl font-semibold  text-ink">' + escapeHtml(plan.habit) + '</p><p class="text-sm text-body">Target: <strong>' + todayTarget + ' min</strong>' + (totalToday > 0 ? ' \u00B7 Total: <strong>' + totalToday + ' min</strong>' : '') + (getTodayResistanceSets() > 0 ? ' \u00B7 Sets: <strong>' + getTodayResistanceSets() + '</strong>' : '') + '</p>' + (totalToday > 0 && getTodayResistanceMinutes() > 0 ? '<p class="text-xs text-mute mt-0.5">Resistance timer: <strong>' + getTodayResistanceMinutes() + ' min</strong> \u00B7 Session: <strong>' + Math.max(0, totalToday - getTodayResistanceMinutes()) + ' min</strong></p>' : '') + '</div></div>';
    }

    if (todayEntry) {
      html += '<div class="bg-canvas-soft rounded-md p-4 text-center mt-5"><p class="text-sm text-body leading-relaxed">' + escapeHtml(todayEntry.feedback) + '</p>' + (todayEntry.note ? '<p class="text-sm text-mute leading-relaxed mt-3 italic">"' + escapeHtml(todayEntry.note) + '"</p>' : '') + '</div>';
    }

    if (todaySets > 0) {
      html += '<div class="mt-4 pt-4 border-t border-hairline"><div class="flex items-center justify-between"><span class="text-xs text-mute">Today\'s sets</span><span class="text-xs text-ink font-medium">' + todaySets + ' completed &middot; ' + todayResMin + ' min</span></div></div>';
    }

    if (!todayEntry) {
      var hasSwTime = stopwatchState.seconds > 0;
      html += '<div class="mt-4 pt-4 border-t border-hairline">';
      if (hasSwTime) {
        html += '<div class="text-center mb-4"><div class="text-2xl font-semibold  text-ink tabular-nums">' + formatStopwatch(stopwatchState.seconds) + '</div><p class="text-xs text-mute mt-1">Current session</p></div>';
        html += '<div class="mb-4"><textarea id="checkin-note" placeholder="How did it feel? (optional)" class="w-full text-sm text-ink bg-canvas rounded-md px-3 py-2 border border-hairline resize-none focus:outline-none focus:border-ink/40 transition-colors" rows="2"></textarea></div>';
        html += '<div class="flex flex-col gap-3"><button id="btn-save-sw-checkin" class="inline-flex items-center justify-center h-10 px-6 bg-primary text-on-primary text-sm font-medium rounded-full no-underline transition-opacity hover:opacity-90">Save to Check-in</button></div>';
      } else if (!isFirstSession) {
        html += '<p class="text-sm text-body text-center mb-3">Add a note about how it went.</p>';
        html += '<textarea id="checkin-note" placeholder="How did it feel? (optional)" class="w-full text-sm text-ink bg-canvas rounded-md px-3 py-2 border border-hairline resize-none focus:outline-none focus:border-ink/40 transition-colors" rows="2"></textarea>';
      }
      html += '</div>';
    }

    html += '</div>';
    html += renderHistory(checkIns, todayStr);
    section.innerHTML = html;

    document.getElementById('btn-save-sw-checkin')?.addEventListener('click', function () {
      var minutes = Math.round(stopwatchState.seconds / 60);
      if (minutes < 1) minutes = 1;
      var noteEl = document.getElementById('checkin-note');
      var note = noteEl ? noteEl.value : '';
      saveCheckInMinutes(plan, minutes, note);
      renderCheckIn(plan); renderAdjustmentHistory();
    });

    document.getElementById('btn-start-timer-recovery')?.addEventListener('click', function () {
      if (timerState.interval) { clearInterval(timerState.interval); timerState.interval = null; }
      timerState.seconds = 300; timerState.status = 'idle';
      renderActionTools(plan);
      var s = document.getElementById('timer-tools'); if (s) s.scrollIntoView({ behavior: 'smooth' });
    });

    document.querySelectorAll('.gap-reason-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var reason = btn.getAttribute('data-reason');
        var feedbackKey = 'habit-build-gap-feedback-' + todayStr;
        try { localStorage.setItem(feedbackKey, reason); } catch {}
        if (typeof posthog !== 'undefined') posthog.capture('gap_feedback', { reason: reason });
        var container = document.getElementById('gap-feedback');
        if (container) { container.style.transition = 'opacity 0.3s'; container.style.opacity = '0.3'; }
      });
    });

    renderTaskSwitchArea(plan);
  }

  function renderHistory(checkIns, todayStr) {
    var entries = Object.entries(checkIns).filter(function (r) { return r[0] !== todayStr; }).sort(function (a, b) { return b[0].localeCompare(a[0]); }).slice(0, 7);
    if (entries.length === 0) return '';
    var rows = '';
    for (var i = 0; i < entries.length; i++) {
      var date = entries[i][0], entry = entries[i][1];
      var d = new Date(date + 'T00:00:00');
      var month = d.toLocaleString('en-US', { month: 'short' });
      var dayNum = d.getDate();
      rows += '<div class="py-2 border-b border-hairline last:border-b-0"><div class="flex items-center justify-between"><span class="text-sm text-body">' + month + ' ' + dayNum + '</span><span class="text-sm text-ink font-medium">' + entry.actualMinutes + ' min</span></div>' + (entry.note ? '<p class="text-xs text-mute mt-1 leading-relaxed truncate">' + escapeHtml(entry.note) + '</p>' : '') + '</div>';
    }
    return '<div class="bg-canvas rounded-md p-6 md:p-8 space-y-4 border border-hairline"><h2 class="text-lg font-semibold  text-ink">Recent Activity</h2>' + rows + '</div>';
  }

  function renderTaskSwitchArea(plan) {
    var area = document.getElementById('task-switch-area');
    if (!area) return;
    area.innerHTML = renderTaskSwitchPanel();
    document.getElementById('btn-switch-task')?.addEventListener('click', function () { refreshTaskSuggestion(); });
    document.getElementById('btn-dismiss-task')?.addEventListener('click', function () { dismissTaskSwitchPanel(); });
  }

  function showInterstitial(plan, answers, onDismiss) {
    var obstacleMessages = {
      "I know what to do but can't start": 'Your plan is built around helping you take the first step.',
      'It feels overwhelming': 'Your plan starts gently so it never feels overwhelming.',
      'I get distracted': 'Your plan is designed to work with your focus, not against it.',
      'I lack motivation': 'Your plan focuses on consistency, not motivation.',
      'I feel too tired': 'Your plan respects your energy and keeps things sustainable.',
      "I don't have enough time": 'Your plan fits into the time you actually have.',
      'I simply forget': 'Your plan helps make your habit a natural part of your day.',
      'Nothing specific': 'Your plan is designed for your situation.',
    };
    var message = 'Your plan is designed for your situation.';
    if (Array.isArray(answers.obstacles)) {
      for (var i = 0; i < answers.obstacles.length; i++) {
        if (obstacleMessages[answers.obstacles[i]]) { message = obstacleMessages[answers.obstacles[i]]; break; }
      }
    }
    var overlay = document.createElement('div');
    overlay.id = 'plan-intro-overlay';
    overlay.style.cssText = 'position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,0.92);backdrop-filter:blur(8px);opacity:0;transition:opacity 0.4s ease;cursor:pointer;';
    overlay.innerHTML = '<div class="text-center px-6 max-w-[400px]" style="transform:translateY(12px);transition:transform 0.4s ease"><div class="w-14 h-14 bg-primary rounded-full flex items-center justify-center mx-auto mb-5"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10M18 20V4M6 20v-4"/></svg></div><h2 class="text-xl font-semibold  text-ink mb-1">' + escapeHtml(plan.habit) + '</h2><p class="text-sm text-body mb-6">' + escapeHtml(plan.goal) + '</p><div class="flex items-center justify-center gap-6 mb-6"><div class="text-center"><div class="text-lg font-semibold  text-ink">' + plan.target + '</div><div class="text-[10px] text-mute mt-0.5">Target</div></div><div class="text-center"><div class="text-lg font-semibold  text-ink">' + plan.minimum + '</div><div class="text-[10px] text-mute mt-0.5">Minimum</div></div><div class="text-center"><div class="text-lg font-semibold  text-ink">' + plan.maximum + '</div><div class="text-[10px] text-mute mt-0.5">Maximum</div></div></div><div class="bg-canvas-soft rounded-md px-4 py-3"><p class="text-sm text-body leading-relaxed">' + escapeHtml(message) + '</p></div><div class="bg-canvas-soft rounded-md px-4 py-3 mt-3"><p class="text-sm text-body leading-relaxed">Tip: Do your habit before the activity you look forward to. Habit first, reward second.</p></div><p class="text-xs text-mute mt-6">Tap anywhere or wait 3 seconds</p></div>';
    document.body.appendChild(overlay);
    requestAnimationFrame(function () { overlay.style.opacity = '1'; var inner = overlay.firstElementChild; if (inner) inner.style.transform = 'translateY(0)'; });
    var dismissed = false;
    function dismiss() {
      if (dismissed) return; dismissed = true; clearTimeout(autoTimer);
      overlay.style.opacity = '0'; var inner = overlay.firstElementChild; if (inner) inner.style.transform = 'translateY(12px)';
      setTimeout(function () { if (document.body.contains(overlay)) document.body.removeChild(overlay); onDismiss(); }, 300);
    }
    var autoTimer = setTimeout(dismiss, 3000);
    overlay.addEventListener('click', dismiss);
  }

  function init() {
    document.getElementById('app').addEventListener('click', function (e) {
      var btn = e.target.closest('button');
      if (!btn) return;
      var plan = planRef;
      if (!plan) return;
      var id = btn.id;
      if (id === 'act-timer-start') startTimer(plan);
      else if (id === 'act-timer-pause') pauseTimer(plan);
      else if (id === 'act-timer-resume') resumeTimer(plan);
      else if (id === 'act-timer-reset') resetTimer(plan);
      else if (id === 'act-early-reset') { timerState.earlyExit = false; timerState.seconds = 300; timerState.status = 'idle'; renderTimerTools(plan); }
      else if (id === 'act-share-finish') {
        var noteEl = document.getElementById('finish-note');
        var note = noteEl ? noteEl.value.trim() : '';
        var todaySets = getTodayResistanceSets();
        var curDay = getCurrentDay(plan.startDate);
        var text = 'Habit Build \u2014 Day ' + curDay + ': ' + escapeHtml(plan.habit) + '\n\u2713 Completed a resistance set (' + todaySets + ' today)\nTarget: ' + plan.target + ' min \u00B7 Minimum: ' + plan.minimum + ' min';
        if (note) text += '\n\n\u201C' + note + '\u201D';
        if (navigator.share) {
          navigator.share({ title: 'Habit Build', text: text }).catch(function () {});
        } else {
          try { navigator.clipboard.writeText(text); } catch {}
          var shareBtn = document.getElementById('act-share-finish');
          if (shareBtn) { shareBtn.textContent = 'Copied!'; setTimeout(function () { if (shareBtn) shareBtn.textContent = 'Share That You Showed Up'; }, 2000); }
        }
      } else if (id === 'act-done') {
        var noteEl = document.getElementById('finish-note');
        var note = noteEl ? noteEl.value.trim() : '';
        if (note) {
          var checkIns = getSavedCheckIns();
          var todayStr = getTodayString();
          if (checkIns[todayStr]) {
            checkIns[todayStr].note = note;
            saveCheckIns(checkIns);
          }
        }
        renderCheckIn(plan);
        var cs = document.getElementById('checkin-section');
        if (cs) cs.scrollIntoView({ behavior: 'smooth' });
      } else if (id === 'act-keep-going-finish') {
        currentTool = 'stopwatch'; stopwatchState.status = 'idle'; stopwatchState.seconds = 0;
        renderCollapsedStopwatch(plan);
        var details = document.querySelector('details:has(#stopwatch-tools)');
        if (details) { details.open = true; setTimeout(function () { details.scrollIntoView({ behavior: 'smooth' }); }, 100); }
      }
      else if (id === 'act-sw-start') startStopwatch(plan);
      else if (id === 'act-sw-pause') pauseStopwatch(plan);
      else if (id === 'act-sw-resume') resumeStopwatch(plan);
      else if (id === 'act-sw-stop') stopStopwatch(plan);
      else if (id === 'act-sw-save') { handleSaveSwSession(plan); resetStopwatch(plan); }
      else if (id === 'act-sw-reset' || id === 'act-sw-reset-p') resetStopwatch(plan);
    });
    try {
      var savedPlan = getSavedPlan();
      if (savedPlan && savedPlan.habit) {
        evaluateAdjustment(savedPlan);
        restoreStopwatchState();
        restoreTimerState();
        renderPlan(savedPlan);
        return;
      }
      var answers = getAssessmentAnswers();
      if (!answers || !answers.habit) { renderError('Please complete the assessment first to generate your personalized plan.'); return; }
      var plan = genPlan(answers);
      savePlan(plan);
      if (typeof posthog !== 'undefined') posthog.capture('plan_generated', { habit: plan.habit, target: plan.target, minimum: plan.minimum, maximum: plan.maximum });
      showInterstitial(plan, answers, function () {
        renderPlan(plan);
      });
    } catch (e) {
      renderError(e.message || 'Could not generate your plan. Please try the assessment again.');
    }
  }

  init();
</script>
