---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Your Plan — Habit Build" description="Your personalized 30-day consistency plan.">
  <Nav currentPage="plan" />

  <main class="flex-1">
    <div class="max-w-[600px] mx-auto px-4 md:px-6 py-12 md:py-16">
      <div id="app"></div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @keyframes ring-glow-pulse {
    0%, 100% { filter: drop-shadow(0 0 4px rgba(0,112,243,0.3)); }
    50% { filter: drop-shadow(0 0 10px rgba(0,112,243,0.5)); }
  }
  .ring-glow { animation: ring-glow-pulse 2s ease-in-out infinite; }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .pulse-dot { animation: pulse-dot 1.5s ease-in-out infinite; }
</style>

<script>
  const ASSESSMENT_KEY = 'habit-build-assessment';
  const PLAN_KEY = 'habit-build-plan';

  function getAssessmentAnswers() {
    try {
      const raw = localStorage.getItem(ASSESSMENT_KEY);
      return raw ? JSON.parse(raw) : null;
    } catch {
      return null;
    }
  }

  function getSavedPlan() {
    try {
      const raw = localStorage.getItem(PLAN_KEY);
      return raw ? JSON.parse(raw) : null;
    } catch {
      return null;
    }
  }

  function savePlan(plan) {
    localStorage.setItem(PLAN_KEY, JSON.stringify(plan));
  }

  const CHECKINS_KEY = 'habit-build-checkins';
  const ADJUSTMENTS_KEY = 'habit-build-adjustments';

  function getDateString(date) {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  }

  function getTodayString() {
    return getDateString(new Date());
  }

  function getSavedCheckIns() {
    try {
      const raw = localStorage.getItem(CHECKINS_KEY);
      return raw ? JSON.parse(raw) : {};
    } catch {
      return {};
    }
  }

  function saveCheckIns(checkIns) {
    localStorage.setItem(CHECKINS_KEY, JSON.stringify(checkIns));
  }

  function getAdjustments() {
    try {
      const raw = localStorage.getItem(ADJUSTMENTS_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch {
      return [];
    }
  }

  function saveAdjustments(adjustments) {
    localStorage.setItem(ADJUSTMENTS_KEY, JSON.stringify(adjustments));
  }

  const TIMER_DURATION_KEY = 'habit-build-timer-duration';

  function getSavedTimerDuration() {
    try {
      var val = parseInt(localStorage.getItem(TIMER_DURATION_KEY), 10);
      return val > 0 ? val : 300;
    } catch { return 300; }
  }

  function saveTimerDuration(seconds) {
    try { localStorage.setItem(TIMER_DURATION_KEY, String(seconds)); } catch {}
  }

  const TIMER_HISTORY_KEY = 'habit-build-timer-history';
  const STOPWATCH_SESSIONS_KEY = 'habit-build-stopwatch-sessions';
  const STOPWATCH_STATE_KEY = 'habit-build-stopwatch-state';

  function getFeedback(actual, target, minimum, maximum) {
    if (actual < minimum) {
      return 'Good job showing up today. Consistency matters more than perfection. Try again tomorrow.';
    }
    if (actual < target) {
      return "You're building momentum. Keep going.";
    }
    if (actual <= maximum) {
      return 'Excellent work. You achieved today\'s goal.';
    }
    return 'Great effort. Be careful not to push too hard. Consistency is more important than intensity.';
  }

  function evaluateAdjustment(plan) {
    const checkIns = getSavedCheckIns();
    const adjustments = getAdjustments();

    const entries = Object.entries(checkIns)
      .filter(function (_ref) { return _ref[1].actualMinutes >= 0; })
      .sort(function (_ref2, _ref3) { return _ref2[0].localeCompare(_ref3[0]); });

    if (entries.length < 5) return false;

    var window$ = entries.slice(-7);
    var hitCount = 0;
    for (var i = 0; i < window$.length; i++) {
      if (window$[i][1].actualMinutes >= window$[i][1].target) {
        hitCount++;
      }
    }

    var hitRate = hitCount / window$.length;
    var adjustment = 0;

    if (hitRate > 0.8) {
      adjustment = Math.floor(Math.random() * 4) + 2;
    } else if (hitRate < 0.4) {
      adjustment = -(Math.floor(Math.random() * 4) + 2);
    }

    if (adjustment === 0) return false;

    var lastAdj = adjustments.length > 0 ? adjustments[adjustments.length - 1] : null;
    if (lastAdj) {
      var lastDate = new Date(lastAdj.date + 'T00:00:00');
      var today = new Date();
      today.setHours(0, 0, 0, 0);
      var daysSince = Math.floor((today - lastDate) / (1000 * 60 * 60 * 24));
      if (daysSince < 5) return false;
    }

    var prevTarget = plan.target;
    var prevMin = plan.minimum;
    var prevMax = plan.maximum;

    var newTarget = prevTarget + adjustment;
    newTarget = Math.round(newTarget / 5) * 5;
    newTarget = Math.max(5, Math.min(120, newTarget));

    if (newTarget === prevTarget) return false;

    plan.target = newTarget;
    plan.minimum = Math.max(3, Math.round(newTarget * 0.5));
    plan.maximum = Math.round(newTarget * 1.5);

    var answers = getAssessmentAnswers();
    plan.explanation = buildExplanation(newTarget, plan.minimum, plan.maximum, answers || {});

    savePlan(plan);

    adjustments.push({
      date: getTodayString(),
      previousTarget: prevTarget,
      newTarget: newTarget,
      previousMinimum: prevMin,
      newMinimum: plan.minimum,
      previousMaximum: prevMax,
      newMaximum: plan.maximum,
      hitRate: Math.round(hitRate * 100),
      direction: adjustment > 0 ? 'increased' : 'decreased',
      amount: Math.abs(adjustment),
    });
    saveAdjustments(adjustments);

    return true;
  }

  function getCurrentDay(startDate) {
    const start = new Date(startDate + 'T00:00:00');
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const diff = Math.floor((today - start) / (1000 * 60 * 60 * 24)) + 1;
    return Math.max(1, Math.min(30, diff));
  }

  function getPlanElapsedDays(startDate) {
    const start = new Date(startDate + 'T00:00:00');
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    return Math.floor((today - start) / (1000 * 60 * 60 * 24)) + 1;
  }

  function isPlanComplete(plan) {
    if (plan.status === 'continuing') return false;
    return getPlanElapsedDays(plan.startDate) >= 30;
  }

  function getPlanStats() {
    const checkIns = getSavedCheckIns();
    const entries = Object.entries(checkIns)
      .filter(function (_ref) { return _ref[1].actualMinutes >= 0; })
      .sort(function (_ref2, _ref3) { return _ref2[0].localeCompare(_ref3[0]); });

    var totalMinutes = 0;
    var activeDays = 0;
    for (var i = 0; i < entries.length; i++) {
      totalMinutes += entries[i][1].actualMinutes;
      activeDays++;
    }

    var first7 = entries.slice(0, 7).filter(function (e) { return e; });
    var last7 = entries.slice(-7).filter(function (e) { return e; });

    function avg(arr) {
      if (arr.length === 0) return 0;
      var sum = 0;
      for (var j = 0; j < arr.length; j++) sum += arr[j][1].actualMinutes;
      return sum / arr.length;
    }

    var firstAvg = avg(first7);
    var lastAvg = avg(last7);
    var trendPct = firstAvg > 0 ? Math.round(((lastAvg - firstAvg) / firstAvg) * 100) : 0;

    var consistencyPct = Math.min(100, Math.round((activeDays / 30) * 100));

    return {
      totalMinutes: totalMinutes,
      activeDays: activeDays,
      consistencyPct: consistencyPct,
      avgMinutes: activeDays > 0 ? Math.round(totalMinutes / activeDays) : 0,
      trendPct: trendPct,
      trendLabel: trendPct > 5 ? 'increased' : trendPct < -5 ? 'decreased' : 'stable',
    };
  }

  function generatePlan(answers) {
    const { habit, time, consistency, obstacles, situation, goal } = answers;

    if (!habit || !time) {
      throw new Error('Assessment answers are incomplete.');
    }

    const baseTargetMap = {
      'None': 10,
      'Less than 15 minutes': 15,
      '15\u201330 minutes': 25,
      '30\u201360 minutes': 40,
      'More than 60 minutes': 60,
    };

    let target = baseTargetMap[time] || 10;

    if (consistency === 'Every day') target += 5;

    if (situation === "I'm doing well but need more structure") target += 5;

    if (Array.isArray(obstacles)) {
      if (obstacles.includes('It feels overwhelming')) {
        target = Math.min(target, 15);
      }
      if (obstacles.includes("I know what to do but can't start")) {
        target = Math.min(target, 20);
      }
    }

    target = Math.round(target / 5) * 5;
    target = Math.max(5, Math.min(120, target));

    const minimum = Math.max(3, Math.round(target * 0.5));
    const maximum = Math.round(target * 1.5);

    const explanation = buildExplanation(target, minimum, maximum, answers);

    return {
      habit,
      goal: goal || `Build a consistent ${habit} habit`,
      target,
      minimum,
      maximum,
      explanation,
      startDate: new Date().toISOString(),
    };
  }

  function buildExplanation(target, minimum, maximum, answers) {
    const { habit, time, consistency, obstacles } = answers;
    const bullets = [];

    if (time === 'None' || consistency === 'Not at all' || consistency === 'A few times') {
      bullets.push(`For ${escapeHtml(habit)}: Start with ${target} min/day.`);
    } else {
      bullets.push(`For ${escapeHtml(habit)}: Aim for ${target} min/day.`);
    }

    if (minimum < target) {
      bullets.push(`On hard days, do ${minimum} min.`);
    }

    if (maximum > target) {
      bullets.push(`Max ${maximum} min to avoid burnout.`);
    }

    return bullets;
  }

  function renderPlanGuide(plan) {
    var bullets = Array.isArray(plan.explanation) ? plan.explanation : [plan.explanation];
    var t = Math.min(1, Math.max(0, (plan.target - plan.minimum) / (plan.maximum - plan.minimum || 1)));
    var x0 = 4, x1 = 80, x2 = 156, y0 = 50, y1 = 6, y2 = 50;
    var dotX = (1-t)*(1-t)*x0 + 2*(1-t)*t*x1 + t*t*x2;
    var dotY = (1-t)*(1-t)*y0 + 2*(1-t)*t*y1 + t*t*y2;
    var pct = Math.round(t * 100);

    var bulletHtml = '';
    for (var bi = 0; bi < bullets.length; bi++) {
      bulletHtml += '<li class="text-sm text-body leading-relaxed pl-4 relative before:content-[\'\'] before:absolute before:left-0 before:top-2.5 before:w-1.5 before:h-1.5 before:rounded-full before:bg-ink/30">' + escapeHtml(bullets[bi]) + '</li>';
    }

    return `
      <div id="plan-guide" class="py-2 space-y-3">
        <ul id="plan-bullets" class="space-y-1.5">${bulletHtml}</ul>
        <div class="pt-2 flex justify-center">
          <svg width="160" height="56" viewBox="0 0 160 56" fill="none" class="text-mute">
            <path d="M4 50 Q80 6 156 50" stroke="#ebebeb" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M4 50 Q80 6 156 50" stroke="#171717" stroke-width="2" stroke-linecap="round" fill="none"
              stroke-dasharray="200" stroke-dashoffset="${200 - 200 * pct / 100}" style="transition:stroke-dashoffset 0.5s"/>
            <circle cx="${dotX.toFixed(1)}" cy="${dotY.toFixed(1)}" r="4" fill="#171717" stroke="white" stroke-width="1.5"/>
            <text x="${x0}" y="54" class="font-mono text-[9px]" fill="#888" text-anchor="middle">${plan.minimum}</text>
            <text x="${x2}" y="54" class="font-mono text-[9px]" fill="#888" text-anchor="middle">${plan.maximum}</text>
            <text x="${dotX.toFixed(1)}" y="0" class="font-mono text-[9px]" fill="#171717" text-anchor="middle" font-weight="500">Target ${plan.target}</text>
          </svg>
        </div>
      </div>
    `;
  }

  function renderPlan(plan) {
    const app = document.getElementById('app');
    if (!app) return;

    if (isPlanComplete(plan)) {
      renderCompletionSummary(plan);
      return;
    }

    var continuing = plan.status === 'continuing';
    var day = continuing ? 3 : getCurrentDay(plan.startDate);
    currentPhase = Math.min(day, 3);

    app.innerHTML = `
      <div class="text-center mb-10">
        <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20V10M18 20V4M6 20v-4"/>
          </svg>
        </div>
        <h1 class="text-2xl md:text-3xl font-semibold tracking-[-1.28px] text-ink mb-2">${continuing ? 'Your Plan' : 'Your 30-Day Plan'}</h1>
        <p class="text-sm text-body">${continuing ? 'Continue building your habit at your own pace.' : 'A personalized plan designed for your situation.'}</p>
      </div>

      <div class="bg-canvas rounded-md p-6 md:p-8 space-y-5" style="box-shadow: 0px 2px 2px rgba(0,0,0,0.04), 0px 8px 8px -8px rgba(0,0,0,0.04), 0 0 0 1px rgba(0,0,0,0.06) inset;">
        <div class="flex items-start gap-4 py-3 border-b border-hairline">
          <span class="w-28 shrink-0 font-mono text-xs text-mute tracking-normal uppercase pt-0.5">Habit</span>
          <span class="text-sm text-ink font-medium">${escapeHtml(plan.habit)}</span>
        </div>

        <div class="flex items-start gap-4 py-3 border-b border-hairline">
          <span class="w-28 shrink-0 font-mono text-xs text-mute tracking-normal uppercase pt-0.5">Goal</span>
          <span class="text-sm text-ink">${escapeHtml(plan.goal)}</span>
        </div>

        ${continuing ? '' : `
        <div class="flex items-start gap-4 py-3 border-b border-hairline">
          <span class="w-28 shrink-0 font-mono text-xs text-mute tracking-normal uppercase pt-0.5">Day</span>
          <span class="text-sm text-ink font-medium">Day ${day} of 30</span>
        </div>
        `}

        <div class="grid grid-cols-3 gap-3 py-3 border-b border-hairline">
          <div class="text-center">
            <div id="plan-target-value" class="text-2xl font-semibold tracking-[-0.96px] text-ink">${plan.target}</div>
            <div class="font-mono text-xs text-mute tracking-normal uppercase mt-1">Target</div>
          </div>
          <div class="text-center">
            <div id="plan-minimum-value" class="text-2xl font-semibold tracking-[-0.96px] text-ink">${plan.minimum}</div>
            <div class="font-mono text-xs text-mute tracking-normal uppercase mt-1">Minimum</div>
          </div>
          <div class="text-center">
            <div id="plan-maximum-value" class="text-2xl font-semibold tracking-[-0.96px] text-ink">${plan.maximum}</div>
            <div class="font-mono text-xs text-mute tracking-normal uppercase mt-1">Maximum</div>
          </div>
        </div>

        ${renderPlanGuide(plan)}
      </div>

      ${currentPhase >= 3 ? '<div id="session-indicator" class="mt-8"></div>' : ''}

      <div id="action-tools" class="mt-8"></div>

      ${currentPhase >= 2 ? '<div id="checkin-section"></div>' : ''}

      ${currentPhase >= 2 ? '<div id="adjustment-history"></div>' : ''}

      <div class="flex items-center justify-center mt-8 gap-3">
        <button id="btn-restart" class="inline-flex items-center h-10 px-4 bg-canvas text-ink text-sm font-medium rounded-[100px] no-underline border border-hairline transition-colors hover:bg-canvas-soft">Retake Assessment</button>
      </div>
    `;

    document.getElementById('btn-restart')?.addEventListener('click', () => {
      try {
        localStorage.removeItem(ASSESSMENT_KEY);
        localStorage.removeItem(PLAN_KEY);
      } catch {}
      window.location.href = '/assessment';
    });

    if (currentPhase >= 2) renderCheckIn(plan);
    renderActionTools(plan);
    if (currentPhase >= 2) renderAdjustmentHistory();
    if (currentPhase >= 3) renderSessionIndicator();
    if (currentPhase >= 3) kickstartStopwatch(plan);
    kickstartTimer(plan);
  }

  function renderError(message) {
    const app = document.getElementById('app');
    if (!app) return;

    app.innerHTML = `
      <div class="text-center mb-10">
        <div class="w-12 h-12 bg-error-soft rounded-full flex items-center justify-center mx-auto mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ee0000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <h1 class="text-2xl md:text-3xl font-semibold tracking-[-1.28px] text-ink mb-2">Something went wrong</h1>
        <p class="text-sm text-body mb-6">${escapeHtml(message)}</p>
        <a
          href="/assessment"
          class="inline-flex items-center h-12 px-6 bg-primary text-on-primary text-base font-medium rounded-[100px] no-underline transition-opacity hover:opacity-90"
        >Take the Assessment</a>
      </div>
    `;
  }

  function updatePlanDisplay(plan) {
    var targetEl = document.getElementById('plan-target-value');
    var minEl = document.getElementById('plan-minimum-value');
    var maxEl = document.getElementById('plan-maximum-value');
    var guideEl = document.getElementById('plan-guide');
    if (targetEl) targetEl.textContent = plan.target;
    if (minEl) minEl.textContent = plan.minimum;
    if (maxEl) maxEl.textContent = plan.maximum;
    if (guideEl) {
      guideEl.outerHTML = renderPlanGuide(plan);
      var newGuide = document.getElementById('plan-guide');
    }
  }

  function renderAdjustmentHistory() {
    var section = document.getElementById('adjustment-history');
    if (!section) return;

    var adjustments = getAdjustments();
    if (adjustments.length === 0) return;

    var rows = '';
    for (var i = adjustments.length - 1; i >= 0; i--) {
      var adj = adjustments[i];
      var d = new Date(adj.date + 'T00:00:00');
      var month = d.toLocaleString('en-US', { month: 'short' });
      var dayNum = d.getDate();
      var arrow = adj.direction === 'increased' ? '\u2191' : '\u2193';
      var color = adj.direction === 'increased' ? 'text-success' : 'text-mute';
      rows += `
        <div class="flex items-center justify-between py-2 border-b border-hairline last:border-b-0">
          <span class="text-sm text-body">${month} ${dayNum}</span>
          <span class="text-sm text-ink font-medium ${color}">${adj.previousTarget} ${arrow} ${adj.newTarget} min</span>
        </div>
      `;
    }

    section.innerHTML = `
      <div class="bg-canvas rounded-md p-6 md:p-8 space-y-4 mt-6" style="box-shadow: 0px 2px 2px rgba(0,0,0,0.04), 0px 8px 8px -8px rgba(0,0,0,0.04), 0 0 0 1px rgba(0,0,0,0.06) inset;">
        <h2 class="text-lg font-semibold tracking-[-0.6px] text-ink">Plan Adjustments</h2>
        <p class="text-sm text-body">Your targets are adjusted based on your performance. Showing the ${adjustments.length} most recent adjustment${adjustments.length > 1 ? 's' : ''}.</p>
        ${rows}
      </div>
    `;
  }

  function calculateAdaptedTarget() {
    const checkIns = getSavedCheckIns();
    const entries = Object.entries(checkIns)
      .filter(function (_ref) { return _ref[1].actualMinutes >= 0; })
      .sort(function (_ref2, _ref3) { return _ref2[0].localeCompare(_ref3[0]); });

    var last7 = entries.slice(-7);
    if (last7.length === 0) return null;

    var total = 0;
    for (var i = 0; i < last7.length; i++) {
      total += last7[i][1].actualMinutes;
    }
    var avg = total / last7.length;
    var target = Math.round(avg / 5) * 5;
    return Math.max(5, Math.min(120, target));
  }

  function handleStartNewPlan(plan) {
    var adaptedTarget = calculateAdaptedTarget();
    var newTarget = adaptedTarget || plan.target;
    var newMin = Math.max(3, Math.round(newTarget * 0.5));
    var newMax = Math.round(newTarget * 1.5);

    var newPlan = {
      habit: plan.habit,
      goal: plan.goal,
      target: newTarget,
      minimum: newMin,
      maximum: newMax,
      explanation: [
        'For ' + escapeHtml(plan.habit) + ': Aim for ' + newTarget + ' min/day.',
        newMin < newTarget ? 'On hard days, do ' + newMin + ' min.' : null,
        'Max ' + newMax + ' min to avoid burnout.',
      ].filter(Boolean),
      startDate: new Date().toISOString(),
    };

    savePlan(newPlan);
    renderPlan(newPlan);
  }

  function handleContinueFreely(plan) {
    plan.status = 'continuing';
    savePlan(plan);
    renderPlan(plan);
  }

  function renderCompletionSummary(plan) {
    const app = document.getElementById('app');
    if (!app) return;

    var stats = getPlanStats();
    var trendSymbol = stats.trendPct > 0 ? '+' : '';
    var trendColor = stats.trendPct > 5 ? 'text-success' : stats.trendPct < -5 ? 'text-mute' : 'text-ink';

    app.innerHTML = `
      <div class="text-center mb-10">
        <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4 ring-glow">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#0070f3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <h1 class="text-2xl md:text-3xl font-semibold tracking-[-1.28px] text-ink mb-2">Congratulations!</h1>
        <p class="text-sm text-body">You've completed your 30-day plan.</p>
      </div>

      <div class="bg-canvas rounded-md p-6 md:p-8 space-y-5" style="box-shadow: 0px 2px 2px rgba(0,0,0,0.04), 0px 8px 8px -8px rgba(0,0,0,0.04), 0 0 0 1px rgba(0,0,0,0.06) inset;">
        <h2 class="text-lg font-semibold tracking-[-0.6px] text-ink">Your 30-Day Summary</h2>

        <div class="grid grid-cols-2 gap-4 py-4 border-b border-hairline">
          <div class="text-center">
            <div class="text-2xl font-semibold tracking-[-0.96px] text-ink">${stats.totalMinutes}</div>
            <div class="font-mono text-xs text-mute tracking-normal uppercase mt-1">Total Minutes</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-semibold tracking-[-0.96px] text-ink">${stats.consistencyPct}%</div>
            <div class="font-mono text-xs text-mute tracking-normal uppercase mt-1">Consistency</div>
          </div>
        </div>

        <div class="py-2 space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-sm text-body">Active Days</span>
            <span class="text-sm text-ink font-medium">${stats.activeDays}/30</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-body">Daily Average</span>
            <span class="text-sm text-ink font-medium">${stats.avgMinutes} min</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-body">Trend</span>
            <span class="text-sm text-ink font-medium ${trendColor}">${trendSymbol}${stats.trendPct}% (${stats.trendLabel})</span>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-3 mt-8">
