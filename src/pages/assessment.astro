---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Assessment — Habit Build" description="Discover your habit-building profile with our quick assessment.">
  <Nav currentPage="assessment" />

  <main class="flex-1 flex flex-col">
    <div class="max-w-[600px] mx-auto px-4 md:px-6 w-full flex-1 flex items-center justify-center">
      <div class="w-full py-4 md:py-6">
        <p class="text-center text-xs text-mute mb-6">7 questions &middot; about 2 minutes</p>
        <div id="app"></div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 30%, 50%, 70%, 90% { transform: translateX(-4px); }
    20%, 40%, 60%, 80% { transform: translateX(4px); }
  }
  .shake { animation: shake 0.4s ease; }

  @keyframes slide-in-right {
    from { opacity: 0; transform: translateX(24px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes slide-in-left {
    from { opacity: 0; transform: translateX(-24px); }
    to { opacity: 1; transform: translateX(0); }
  }
  .slide-in-right { animation: slide-in-right 0.25s ease-out; }
  .slide-in-left { animation: slide-in-left 0.25s ease-out; }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .fade-in { animation: fade-in 0.3s ease-out; }
</style>

<script>
  const questions = [
    {
      id: 'habit',
      type: 'text',
      question: 'What would you like to make a habit?',
      placeholder: 'e.g., reading, coding, exercise, meditation...',
      help: 'Pick something specific you want to work on.',
    },
    {
      id: 'time',
      type: 'radio',
      question: 'How much time do you currently spend on it?',
      help: 'Be honest — this helps us set the right starting point.',
      options: [
        'None',
        'Less than 15 minutes',
        '15\u201330 minutes',
        '30\u201360 minutes',
        'More than 60 minutes',
      ],
    },
    {
      id: 'consistency',
      type: 'radio',
      question: 'How consistent have you been over the past month?',
      help: 'Think about the last 30 days. No judgment either way.',
      options: [
        'Not at all',
        'A few times',
        'About half the days',
        'Most days',
        'Every day',
      ],
    },
    {
      id: 'obstacles',
      type: 'checkbox',
      question: 'What typically gets in the way?',
      help: 'Select all that apply.',
      options: [
        'I know what to do but can\'t start',
        'It feels overwhelming',
        'I get distracted',
        'I lack motivation',
        'I feel too tired',
        'I don\'t have enough time',
        'I simply forget',
        'Nothing specific',
      ],
    },
    {
      id: 'situation',
      type: 'radio',
      question: 'What best describes your current situation?',
      help: 'This helps us tailor the approach to where you are right now.',
      options: [
        'I\'m just getting started',
        'I\'ve tried before but struggled to stick with it',
        'I\'m somewhat consistent but want to improve',
        'I\'m doing well but need more structure',
      ],
    },
    {
      id: 'goal',
      type: 'textarea',
      question: 'What is your biggest goal for the next 30 days?',
      placeholder: 'e.g., Read for 20 minutes every day, write 500 words daily...',
      help: 'Think about what success looks like in one month.',
      optional: true,
    },
    {
      id: 'timeSlot',
      type: 'radio',
      question: 'What time of day works best for you?',
      help: 'Pick a time you can stick with most days.',
      options: [
        'Morning',
        'Midday',
        'Afternoon',
        'Evening',
        'No preference',
      ],
    },
  ];

  const STORAGE_KEY = 'habit-build-assessment';
  let slideDirection = 'right';
  let encouragementMsg = '';
  let assessmentStarted = false;

  const encouragementMap = {
    habit: 'Great choice.',
    time: "That's honest — helps us plan better.",
    consistency: 'Good to know.',
    obstacles: "We'll work around those.",
    situation: 'Perfect — we can work with that.',
    goal: 'Love it.',
    timeSlot: 'Noted.',
  };

  import { getAssessmentAnswers, saveAssessmentAnswers, clearAssessment } from '../lib/utils.js';

  function getSavedAnswers() {
    return getAssessmentAnswers() || {};
  }

  function saveAnswers(answers) {
    saveAssessmentAnswers(answers);
  }

  function clearAnswers() {
    clearAssessment();
  }

  function render() {
    const answers = getSavedAnswers();
    const urlParams = new URLSearchParams(window.location.search);
    encouragementMsg = encouragementMsg || '';
    if (parseInt(urlParams.get('step'), 10) <= 1) encouragementMsg = '';
    const stepParam = parseInt(urlParams.get('step'), 10);
    const step = !isNaN(stepParam) && stepParam >= 1 && stepParam <= questions.length + 1 ? stepParam : 1;
    const isComplete = step === questions.length + 1;

    if (step === 1 && !assessmentStarted) {
      assessmentStarted = true;
      if (typeof posthog !== 'undefined') posthog.capture('assessment_started');
    }

    const app = document.getElementById('app');
    if (!app) return;

    if (isComplete) {
      encouragementMsg = '';
      renderSummary(app, answers);
      return;
    }

    renderQuestion(app, step, answers, questions[step - 1]);
  }

  const stepLabels = [
    'First things first',
    'Your availability',
    'Your consistency',
    'Anticipating obstacles',
    'Your plan',
    'Your goal',
    'Your ideal time',
  ];

  function renderProgress(current, total) {
    const pct = ((current - 1) / total) * 100;
    const label = stepLabels[current - 1] || '';
    return `
      <div class="mb-10 fade-in">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs text-mute">${label}</span>
          <span class="text-xs text-mute">${Math.round(pct)}%</span>
        </div>
        <div class="h-1 bg-canvas-subtle rounded-full overflow-hidden">
          <div class="h-full bg-primary rounded-full transition-all duration-500" style="width:${pct}%"></div>
        </div>
      </div>
    `;
  }

  function renderQuestion(app, step, answers, q) {
    const saved = answers[q.id];
    const total = questions.length;
    const animClass = slideDirection === 'right' ? 'slide-in-right' : 'slide-in-left';

    let inputHtml = '';

    if (q.type === 'text') {
      inputHtml = `
        <input
          id="input-${q.id}"
          type="text"
          value="${escapeHtml(saved || '')}"
          placeholder="${escapeHtml(q.placeholder || '')}"
          class="w-full h-12 px-3 bg-canvas text-ink text-base border border-hairline rounded-md outline-none transition-colors focus:border-ink"
          autocomplete="off"
        />
      `;
    } else if (q.type === 'textarea') {
      inputHtml = `
        <textarea
          id="input-${q.id}"
          rows="3"
          placeholder="${escapeHtml(q.placeholder || '')}"
          class="w-full px-3 py-3 bg-canvas text-ink text-base border border-hairline rounded-md outline-none resize-none transition-colors focus:border-ink"
        >${escapeHtml(saved || '')}</textarea>
      `;
    } else if (q.type === 'radio') {
      inputHtml = '<div id="radio-group" class="space-y-2">';
      inputHtml += q.options.map((opt, i) => {
        const checked = saved === opt ? 'checked' : '';
        return `
          <label class="flex items-center gap-3 px-4 h-12 bg-canvas border border-hairline rounded-md cursor-pointer transition-colors hover:border-ink has-[:checked]:border-ink has-[:checked]:bg-canvas-soft">
            <input type="radio" name="${q.id}" value="${escapeHtml(opt)}" ${checked} class="appearance-none w-4 h-4 border-2 border-hairline-strong rounded-full shrink-0 checked:border-[5px] checked:border-ink transition-all" />
            <span class="text-sm text-ink flex-1">${escapeHtml(opt)}</span>
            <span class="text-[10px] text-hairline-strong tabular-nums">${i + 1}</span>
          </label>
        `;
      }).join('');
      inputHtml += '</div>';
    } else if (q.type === 'checkbox') {
      inputHtml = '<div id="checkbox-group" class="space-y-2">';
      inputHtml += q.options.map((opt, i) => {
        const checked = Array.isArray(saved) && saved.includes(opt) ? 'checked' : '';
        return `
          <label class="flex items-center gap-3 px-4 h-12 bg-canvas border border-hairline rounded-md cursor-pointer transition-colors hover:border-ink has-[:checked]:border-ink has-[:checked]:bg-canvas-soft">
            <input type="checkbox" name="${q.id}" value="${escapeHtml(opt)}" ${checked} class="appearance-none w-4 h-4 border-2 border-hairline-strong rounded-sm shrink-0 checked:bg-ink checked:border-ink transition-all" />
            <span class="text-sm text-ink flex-1">${escapeHtml(opt)}</span>
            <span class="text-[10px] text-hairline-strong tabular-nums">${i + 1}</span>
          </label>
        `;
      }).join('');
      inputHtml += '</div>';
    }

    const isLast = step === total;
    const optionalBadge = q.optional ? '<span class="text-xs text-mute font-normal ml-1">(optional)</span>' : '';

    app.innerHTML = `
      ${renderProgress(step, total)}
      ${encouragementMsg ? '<div id="encouragement-banner" class="fade-in mb-4 bg-success/10 rounded-md px-4 py-2.5 text-center"><p class="text-sm text-success font-medium">' + escapeHtml(encouragementMsg) + '</p></div>' : ''}
      <div id="question-card" class="${animClass} bg-canvas rounded-lg p-6 md:p-8 border border-hairline">
        <h2 class="text-xl md:text-2xl font-semibold text-ink mb-2">${escapeHtml(q.question)}${optionalBadge}</h2>
        ${q.help ? `<p class="text-sm text-body mb-6">${escapeHtml(q.help)}</p>` : ''}
        <div id="input-area" class="space-y-2">
          ${inputHtml}
        </div>
        <div id="error-msg" class="hidden mt-3">
          <p class="text-sm text-error flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span id="error-text"></span>
          </p>
        </div>
        <div class="flex items-center justify-between mt-8">
          <button id="btn-back" class="inline-flex items-center h-10 px-4 bg-canvas text-ink text-sm font-medium rounded-full no-underline border border-hairline transition-colors hover:bg-canvas-soft ${step === 1 ? 'invisible' : ''}">Back</button>
          <button id="btn-next" class="inline-flex items-center h-10 px-5 bg-primary text-on-primary text-sm font-medium rounded-full no-underline transition-opacity hover:opacity-90">${isLast ? 'Complete' : 'Next'}</button>
        </div>
        ${isLast ? '<div class="text-center mt-3"><a href="/assessment?step=' + (total + 1) + '" class="text-xs text-mute hover:text-link transition-colors no-underline">Review answers</a></div>' : ''}
        ${q.type === 'radio' || q.type === 'checkbox' ? '<p class="text-[11px] text-hairline-strong text-center mt-3">Press 1\u2013' + q.options.length + ' to select</p>' : ''}
      </div>
    `;

    // Auto-dismiss encouragement after 3 seconds
    var encouragementEl = document.getElementById('encouragement-banner');
    if (encouragementEl) {
      setTimeout(function () {
        if (encouragementEl && encouragementEl.parentNode) {
          encouragementEl.style.transition = 'opacity 0.3s';
          encouragementEl.style.opacity = '0';
          setTimeout(function () { if (encouragementEl && encouragementEl.parentNode) encouragementEl.parentNode.removeChild(encouragementEl); }, 300);
        }
      }, 3000);
    }

    // Focus input if text type
    const textInput = document.getElementById(`input-${q.id}`);
    if (textInput && (q.type === 'text' || q.type === 'textarea')) {
      setTimeout(() => textInput.focus(), 100);
    }

    // Event listeners
    document.getElementById('btn-next')?.addEventListener('click', () => handleNext(step, q));
    document.getElementById('btn-back')?.addEventListener('click', () => handleBack(step));

    // Enter key for text inputs
    if (textInput) {
      textInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && q.type === 'text') {
          e.preventDefault();
          handleNext(step, q);
        }
      });
    }

    // Keyboard shortcuts for radio/checkbox
    if (q.type === 'radio' || q.type === 'checkbox') {
      document.addEventListener('keydown', function handler(e) {
        // Remove listener on navigation
        if (!document.getElementById('question-card')) {
          document.removeEventListener('keydown', handler);
          return;
        }

        const num = parseInt(e.key, 10);
        if (num >= 1 && num <= q.options.length) {
          const idx = num - 1;
          const inputs = document.querySelectorAll(`input[name="${q.id}"]`);
          if (inputs[idx]) {
            inputs[idx].click();
            inputs[idx].focus();
          }
        }

        if (e.key === 'Enter') {
          e.preventDefault();
          handleNext(step, q);
        }
      });
    }
  }

  function collectAnswer(step, q) {
    if (q.type === 'text') {
      const el = document.getElementById(`input-${q.id}`);
      return el ? el.value.trim() : '';
    }
    if (q.type === 'textarea') {
      const el = document.getElementById(`input-${q.id}`);
      return el ? el.value.trim() : '';
    }
    if (q.type === 'radio') {
      const checked = document.querySelector(`input[name="${q.id}"]:checked`);
      return checked ? checked.value : '';
    }
    if (q.type === 'checkbox') {
      const checked = document.querySelectorAll(`input[name="${q.id}"]:checked`);
      return Array.from(checked).map((el) => el.value);
    }
    return '';
  }

  function validateAnswer(value, q) {
    if (q.optional) return true;
    if (q.type === 'checkbox') {
      return Array.isArray(value) && value.length > 0;
    }
    if (q.type === 'radio') {
      return typeof value === 'string' && value.length > 0;
    }
    return typeof value === 'string' && value.length > 0;
  }

  function showError(message) {
    const msgEl = document.getElementById('error-msg');
    const textEl = document.getElementById('error-text');
    const card = document.getElementById('question-card');
    const inputArea = document.getElementById('input-area');
    if (msgEl && textEl) {
      textEl.textContent = message;
      msgEl.classList.remove('hidden');
    }
    if (card) {
      card.classList.remove('shake');
      void card.offsetWidth;
      card.classList.add('shake');
    }
    if (inputArea) {
      const inputs = inputArea.querySelectorAll('input, textarea');
      inputs.forEach(inp => {
        inp.classList.remove('border-error');
        void inp.offsetWidth;
        inp.classList.add('border-error');
      });
    }
  }

  function hideError() {
    const msgEl = document.getElementById('error-msg');
    const inputArea = document.getElementById('input-area');
    if (msgEl) msgEl.classList.add('hidden');
    if (inputArea) {
      inputArea.querySelectorAll('input, textarea').forEach(inp => {
        inp.classList.remove('border-error');
      });
    }
  }

  function handleNext(step, q) {
    const value = collectAnswer(step, q);
    if (!validateAnswer(value, q)) {
      if (q.type === 'checkbox') {
        showError('Please select at least one option.');
      } else if (q.type === 'radio') {
        showError('Please select an option.');
      } else {
        showError('Please enter an answer.');
      }
      return;
    }

    hideError();
    const answers = getSavedAnswers();
    answers[q.id] = value;
    saveAnswers(answers);

    if (typeof posthog !== 'undefined') posthog.capture('question_answered', { question_id: q.id, step: step });

    encouragementMsg = encouragementMap[q.id] || '';
    if (step === questions.length) {
      window.location.href = '/plan';
      return;
    }
    slideDirection = 'right';
    navigateTo(step + 1);
  }

  function handleBack(step) {
    const q = questions[step - 1];
    const value = collectAnswer(step, q);
    const answers = getSavedAnswers();
    if (validateAnswer(value, q)) {
      answers[q.id] = value;
      saveAnswers(answers);
    }
    hideError();
    slideDirection = 'left';
    encouragementMsg = '';
    navigateTo(step - 1);
  }

  function navigateTo(step) {
    const params = new URLSearchParams(window.location.search);
    params.set('step', step.toString());
    window.history.pushState({ step }, '', `?${params.toString()}`);
    render();
  }

  function renderSummary(app, answers) {
    if (typeof posthog !== 'undefined') posthog.capture('assessment_completed');
    const labels = {
      habit: 'Habit',
      time: 'Current time',
      consistency: 'Past month consistency',
      obstacles: 'Common obstacles',
      situation: 'Current situation',
      goal: '30-day goal',
    };

    const items = questions.map((q) => {
      let val = answers[q.id];
      if (!val || (Array.isArray(val) && val.length === 0)) {
        val = 'Not answered';
      } else if (Array.isArray(val)) {
        val = val.join(', ');
      }
      return { label: labels[q.id], value: val };
    });

    app.innerHTML = `
      <div class="text-center mb-10 fade-in">
        <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <h1 class="text-2xl md:text-3xl font-semibold text-ink mb-2">Assessment Complete</h1>
        <p class="text-sm text-body">Here is a summary of your responses. Your personalized 30-day plan is ready.</p>
      </div>

      <div class="bg-canvas rounded-lg p-6 md:p-8 fade-in border border-hairline">
        ${items.map((item, i) => `
          <div class="flex items-start gap-4 py-3 ${i < items.length - 1 ? 'border-b border-hairline' : ''}">
            <span class="w-24 shrink-0 text-xs text-mute pt-0.5">${escapeHtml(item.label)}</span>
            <span class="text-sm text-ink flex-1">${escapeHtml(item.value)}</span>
            <button class="edit-summary-btn text-xs text-link hover:underline shrink-0 mt-0.5 bg-transparent border-none cursor-pointer p-0" data-step="${i + 1}">Edit</button>
          </div>
        `).join('')}
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center mt-8 gap-3">
        <a href="/plan" class="inline-flex items-center h-10 px-6 bg-primary text-on-primary text-sm font-medium rounded-full no-underline transition-opacity hover:opacity-90">Start with 5 minutes</a>
        <button id="btn-restart" class="inline-flex items-center h-10 px-4 bg-canvas text-ink text-sm font-medium rounded-full no-underline border border-hairline transition-colors hover:bg-canvas-soft">Start Over</button>
      </div>
    `;

    document.getElementById('btn-restart')?.addEventListener('click', () => {
      clearAnswers();
      slideDirection = 'right';
      navigateTo(1);
    });

    document.querySelectorAll('.edit-summary-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var step = parseInt(this.getAttribute('data-step'), 10);
        slideDirection = 'right';
        navigateTo(step);
      });
    });
  }

  function escapeHtml(str) {
    if (typeof str !== 'string') return '';
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
  }

  // Handle browser back/forward
  window.addEventListener('popstate', () => {
    slideDirection = 'left';
    render();
  });

  // Initial render
  render();
</script>
