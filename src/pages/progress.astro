---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Progress — Habit Build" description="Your daily, weekly, and monthly habit progress.">
  <Nav currentPage="progress" />

  <main class="flex-1">
    <div class="max-w-[600px] mx-auto px-4 md:px-6 py-12 md:py-16">
      <div id="app">
        <div class="space-y-4 animate-pulse">
          <div class="text-center mb-6"><div class="h-7 w-40 bg-canvas-subtle rounded mx-auto mb-2"></div><div class="h-4 w-48 bg-canvas-subtle rounded mx-auto"></div></div>
<div class="bg-canvas rounded-md p-6 border border-hairline"><div class="h-3 w-24 bg-canvas-subtle rounded mb-4"></div><div class="grid grid-cols-3 gap-3 mb-4"><div class="h-10 bg-canvas-subtle rounded"></div><div class="h-10 bg-canvas-subtle rounded"></div><div class="h-10 bg-canvas-subtle rounded"></div></div><div class="h-2 bg-canvas-subtle rounded-full mb-3"></div><div class="h-24 bg-canvas-subtle rounded"></div></div>
<div class="bg-canvas rounded-md p-6 border border-hairline"><div class="h-3 w-24 bg-canvas-subtle rounded mb-4"></div><div class="h-32 bg-canvas-subtle rounded"></div></div>
<div class="bg-canvas rounded-md p-6 border border-hairline"><div class="h-3 w-24 bg-canvas-subtle rounded mb-4"></div><div class="h-20 bg-canvas-subtle rounded"></div></div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { getSavedPlan, getSavedCheckIns, getAdjustments, getResistanceSets, getTodayString, formatDate, getWeekStart, getDateString, getCurrentDay, daysSince, escapeHtml, getPreviousPlan, getPreviousCheckIns, exportAllData } from '../lib/utils.js';
  import { safeSet } from '../lib/utils.js';

  function getCompareStats(prevPlan, prevCheckIns) {
    if (!prevPlan || !prevPlan.startDate) return null;
    var start = prevPlan.startDate.split('T')[0];
    var total = 0, active = 0;
    var ds = Math.min(30, daysSince(start));
    for (var i = 0; i < ds; i++) {
      var d = new Date(start + 'T00:00:00'); d.setDate(d.getDate() + i);
      var entry = prevCheckIns[getDateString(d)];
      if (entry) { total += entry.actualMinutes; active++; }
    }
    return { totalMinutes: total, activeDays: active, consistencyPct: Math.min(100, Math.round((active / Math.max(1, ds)) * 100)), target: prevPlan.target, minimum: prevPlan.minimum, maximum: prevPlan.maximum, habit: prevPlan.habit, days: ds };
  }

  function calculateBestPeriod(checkIns, planStart, planDays, minimum) {
    var best = 0, current = 0;
    for (var i = 0; i < planDays; i++) {
      var d = new Date(planStart + 'T00:00:00'); d.setDate(d.getDate() + i);
      var entry = checkIns[getDateString(d)];
      if (entry && entry.actualMinutes >= minimum) { current++; if (current > best) best = current; }
      else { current = 0; }
    }
    return best;
  }

  function calculateTargetHits(checkIns, planStart, planDays, target) {
    var hits = 0;
    for (var i = 0; i < planDays; i++) {
      var d = new Date(planStart + 'T00:00:00'); d.setDate(d.getDate() + i);
      var entry = checkIns[getDateString(d)];
      if (entry && entry.actualMinutes >= target) hits++;
    }
    return hits;
  }

  function renderHeatmap(checkIns, planStart, planDays) {
    var weeks = []; var currentWeek = [];
    var startDate = new Date(planStart + 'T00:00:00');
    var startDay = startDate.getDay(); var offset = startDay === 0 ? 6 : startDay - 1;
    for (var pad = 0; pad < offset; pad++) currentWeek.push(null);
    for (var i = 0; i < Math.min(planDays, 84); i++) {
      var d = new Date(planStart + 'T00:00:00'); d.setDate(d.getDate() + i);
      var ds = getDateString(d);
      var entry = checkIns[ds];
      currentWeek.push(entry ? entry.actualMinutes : 0);
      if (currentWeek.length === 7) { weeks.push(currentWeek); currentWeek = []; }
    }
    if (currentWeek.length > 0) weeks.push(currentWeek);
    if (weeks.length === 0) return '';

    var html = '<div class="space-y-1">';
    for (var wi = 0; wi < weeks.length; wi++) {
      var active = 0, total = 0;
      for (var di = 0; di < weeks[wi].length; di++) {
        if (weeks[wi][di] !== null) { total++; if (weeks[wi][di] > 0) active++; }
      }
      html += '<div class="flex items-center justify-between py-1.5 border-b border-hairline last:border-b-0"><span class="text-sm text-body">Week ' + (wi + 1) + '</span><span class="text-sm text-ink font-medium">' + active + '/' + total + ' days</span></div>';
    }
    html += '</div>';
    return html;
  }

  let showCompare = false;

  function renderProgress() {
    const app = document.getElementById('app');
    if (!app) return;
    const plan = getSavedPlan();
    const checkIns = getSavedCheckIns();

    if (!plan || !plan.habit) {
      app.innerHTML = '<div class="text-center mb-10"><div class="w-12 h-12 bg-canvas-subtle rounded-full flex items-center justify-center mx-auto mb-4"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-body"><path d="M12 20V10M18 20V4M6 20v-4"/></svg></div><h1 class="text-2xl md:text-3xl font-semibold  text-ink mb-2">No plan yet</h1><p class="text-sm text-body mb-6">Complete the assessment to get a personalized 30-day plan and start tracking your progress.</p><div class="flex items-center justify-center gap-3"><a href="/assessment" class="inline-flex items-center h-12 px-6 bg-primary text-on-primary text-base font-medium rounded-full no-underline transition-opacity hover:opacity-90">Take Assessment</a><a href="/" class="inline-flex items-center h-12 px-6 bg-canvas text-ink text-base font-medium rounded-full no-underline border border-hairline transition-colors hover:bg-canvas-soft">Go Home</a></div></div>';
      return;
    }

    const todayStr = getTodayString();
    const todayEntry = checkIns[todayStr] || null;
    const allSets = getResistanceSets();
    var totalSets = 0; for (var k in allSets) totalSets += allSets[k];

    var hasAnyActivity = Object.keys(checkIns).length > 0 || totalSets > 0;
    if (!hasAnyActivity) {
      app.innerHTML = '<div class="text-center mb-10"><div class="w-16 h-16 bg-canvas-subtle rounded-full flex items-center justify-center mx-auto mb-6"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-body"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></div><h1 class="text-2xl md:text-3xl font-semibold  text-ink mb-2">Your Progress</h1><p class="text-sm text-body mb-6">Track your consistency over time.</p></div><div class="bg-canvas rounded-md p-8 text-center" style="box-shadow:0px 2px 2px rgba(0,0,0,0.04),0px 8px 8px -8px rgba(0,0,0,0.04),0 0 0 1px rgba(0,0,0,0.06) inset;"><div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ink"><path d="M12 20V10M18 20V4M6 20v-4"/></svg></div><p class="text-base font-semibold  text-ink mb-1">Start your first session</p><p class="text-sm text-body mb-6">Complete a timer session or check-in to begin tracking your progress here.</p><a href="/plan" class="inline-flex items-center h-12 px-6 bg-primary text-on-primary text-base font-medium rounded-full no-underline transition-opacity hover:opacity-90">Go to Plan</a></div>';
      return;
    }

    const weekStart = getWeekStart();
    const weekDays = [];
    for (let i = 0; i < 7; i++) {
      const d = new Date(weekStart); d.setDate(d.getDate() + i);
      weekDays.push({ date: getDateString(d), entry: checkIns[getDateString(d)] || null });
    }
    let weeklyTotal = 0, weeklyActiveDays = 0;
    for (const wd of weekDays) { if (wd.entry) { weeklyTotal += wd.entry.actualMinutes; weeklyActiveDays++; } }
    const weeklyAvg = weeklyActiveDays > 0 ? Math.round(weeklyTotal / weeklyActiveDays) : 0;
    const weeklyConsistencyPct = Math.round((weeklyActiveDays / 7) * 100);

    const planStart = plan.startDate ? plan.startDate.split('T')[0] : getTodayString();
    const dayNum = getCurrentDay(planStart);
    let monthlyTotal = 0, monthlyActiveDays = 0;
    const planDays = Math.min(30, daysSince(planStart));
    for (let i = 0; i < planDays; i++) {
      const d = new Date(planStart + 'T00:00:00'); d.setDate(d.getDate() + i);
      const entry = checkIns[getDateString(d)];
      if (entry) { monthlyTotal += entry.actualMinutes; monthlyActiveDays++; }
    }
    const consistencyScore = Math.round((monthlyActiveDays / Math.max(1, planDays)) * 100);
    const bestPeriod = calculateBestPeriod(checkIns, planStart, planDays, plan.minimum);
    const targetHits = calculateTargetHits(checkIns, planStart, planDays, plan.target);

    let dailyStatus = 'Not Started', dailyStatusClass = 'text-mute', dailyPct = 0;
    if (todayEntry) {
      dailyPct = Math.min(100, Math.round((todayEntry.actualMinutes / plan.target) * 100));
      if (todayEntry.actualMinutes >= plan.target) { dailyStatus = 'Target Achieved'; dailyStatusClass = 'text-success'; }
      else if (todayEntry.actualMinutes > 0) { dailyStatus = 'In Progress'; dailyStatusClass = 'text-body'; }
    }

    var sparkData = [], hasSparkData = false, maxSpark = 0;
    for (var si = 13; si >= 0; si--) {
      var sd = new Date(); sd.setDate(sd.getDate() - si);
      var entry = checkIns[getDateString(sd)];
      var val = entry ? entry.actualMinutes : 0;
      sparkData.push(val); if (val > 0) hasSparkData = true; if (val > maxSpark) maxSpark = val;
    }
    var sparklineHtml = '';
    if (hasSparkData) {
      var spSvgW = 280, spSvgH = 44, spPad = 4, spPlotH = spSvgH - spPad * 2;
      var spStep = (spSvgW - spPad * 2) / (sparkData.length - 1);
      var spPoints = [], spDots = '';
      for (var si = 0; si < sparkData.length; si++) {
        var spX = spPad + si * spStep;
        var spY = maxSpark > 0 ? (spSvgH - spPad) - (sparkData[si] / maxSpark) * spPlotH : spSvgH / 2;
        spPoints.push(spX.toFixed(1) + ',' + spY.toFixed(1));
        spDots += '<circle cx="' + spX.toFixed(1) + '" cy="' + spY.toFixed(1) + '" r="1.5" fill="var(--color-primary)"/>';
      }
      var fwSum = 0, swSum = 0;
      for (var fi = 0; fi < 7; fi++) { fwSum += sparkData[fi]; swSum += sparkData[fi + 7]; }
      var fwAvg = fwSum / 7, swAvg = swSum / 7;
      var trendIcon, trendText, trendColor;
      if (swAvg > fwAvg * 1.1 || (fwAvg === 0 && swAvg > 0)) { trendIcon = '\u2191'; trendText = 'Trending up this week'; trendColor = 'text-success'; }
      else if (swAvg < fwAvg * 0.9) { trendIcon = '\u2193'; trendText = 'Slight dip \u2014 that\u2019s okay, tomorrow is fresh.'; trendColor = 'text-mute'; }
      else { trendIcon = '\u2192'; trendText = 'Holding steady'; trendColor = 'text-ink'; }
      sparklineHtml = '<div class="py-3 border-t border-hairline"><svg width="100%" height="44" viewBox="0 0 ' + spSvgW + ' ' + spSvgH + '" preserveAspectRatio="xMidYMid meet" class="block"><polyline points="' + spPoints.join(' ') + '" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>' + spDots + '</svg><div class="flex items-center justify-center gap-1.5 mt-1"><span class="text-sm ' + trendColor + ' font-medium">' + trendIcon + '</span><span class="text-xs text-body">' + trendText + '</span></div></div>';
    }

    var heatmapHtml = renderHeatmap(checkIns, planStart, planDays);

    var prevPlan = getPreviousPlan(); var prevCheckIns = getPreviousCheckIns();
    var prevStats = prevPlan ? getCompareStats(prevPlan, prevCheckIns) : null;
    var yesterday = new Date(); yesterday.setDate(yesterday.getDate() - 1);
    var yesterdayMissed = planDays > 1 && !checkIns[getDateString(yesterday)] && !todayEntry;

    let html = '';
    if (yesterdayMissed) {
      html += '<div class="bg-canvas rounded-md p-4 mb-6 border border-hairline"><p class="text-sm text-body leading-relaxed mb-3">Missed yesterday? That\'s normal. Here\'s today\'s target: <strong>' + plan.target + ' min</strong>.</p><a href="/plan" class="inline-flex items-center h-9 px-4 bg-primary text-on-primary text-sm font-medium rounded-full no-underline transition-opacity hover:opacity-90">Go to Plan</a></div>';
    }

    html += '<div class="text-center mb-6"><h1 class="text-2xl md:text-3xl font-semibold  text-ink mb-2">Your Progress</h1><p class="text-sm text-body">Track your consistency over time.</p></div>';

    if (prevStats) {
      html += '<div class="flex items-center justify-center mb-6"><label class="flex items-center gap-2 cursor-pointer select-none"><input type="checkbox" id="toggle-compare" class="appearance-none w-8 h-4 bg-hairline-strong rounded-full shrink-0 relative cursor-pointer transition-colors checked:bg-primary after:content-[\'\'] after:absolute after:top-0.5 after:left-0.5 after:w-3 after:h-3 after:bg-white after:rounded-full after:transition-transform checked:after:translate-x-4" ' + (showCompare ? 'checked' : '') + '><span class="text-sm text-body">Compare with previous 30 days</span></label></div>';
    }

    // Heatmap
    if (heatmapHtml) {
      html += '<div class="bg-canvas rounded-md p-6 md:p-8 mb-6 border border-hairline"><div class="flex items-center gap-2 mb-4"><span class="text-xs text-mute">How your weeks are going</span></div>' + heatmapHtml + '</div>';
    }

    // Daily Progress
    html += '<div class="bg-canvas rounded-md p-6 md:p-8 space-y-5 mb-6 border border-hairline"><div class="flex items-center gap-2"><span class="text-xs text-mute">How today went</span></div><div class="grid grid-cols-3 gap-3 py-3 border-b border-hairline"><div class="text-center"><div class="text-xl font-semibold  text-ink">' + plan.target + '</div><div class="text-xs text-mute mt-1">Target</div></div><div class="text-center"><div class="text-xl font-semibold  text-ink">' + plan.minimum + '</div><div class="text-xs text-mute mt-1">Minimum</div></div><div class="text-center"><div class="text-xl font-semibold  text-ink">' + plan.maximum + '</div><div class="text-xs text-mute mt-1">Maximum</div></div></div><div class="py-2"><div class="flex items-center justify-between mb-2"><span class="text-sm text-body">Today\'s Progress</span><span class="text-sm text-ink font-medium">' + (todayEntry ? todayEntry.actualMinutes : 0) + ' min</span></div><div class="h-2 bg-canvas-subtle rounded-full overflow-hidden"><div class="h-full bg-primary rounded-full transition-all duration-500" style="width:' + dailyPct + '%"></div></div></div><div class="flex items-center justify-between py-2"><span class="text-sm text-body">Status</span><span class="text-sm font-medium ' + dailyStatusClass + '">' + dailyStatus + '</span></div>' + sparklineHtml + (todayEntry ? '<div class="bg-canvas-soft rounded-md p-3 text-center"><p class="text-sm text-body leading-relaxed">' + escapeHtml(todayEntry.feedback) + '</p>' + (todayEntry.note ? '<p class="text-xs text-mute mt-2 italic">"' + escapeHtml(todayEntry.note) + '"</p>' : '') + '</div>' : '<div class="bg-canvas-soft rounded-md p-3 text-center"><p class="text-sm text-body leading-relaxed">Start your habit today to begin tracking progress.</p></div>') + '</div>';

    // Weekly Progress
    if (weeklyActiveDays > 0) {
    html += '<div class="bg-canvas rounded-md p-6 md:p-8 space-y-5 mb-6 border border-hairline"><div class="flex items-center gap-2"><span class="text-xs text-mute">This week</span></div><div class="grid grid-cols-2 gap-4 py-3 border-b border-hairline"><div class="text-center"><div class="text-xl font-semibold  text-ink">' + weeklyTotal + '</div><div class="text-xs text-mute mt-1">Total min</div></div><div class="text-center"><div class="text-xl font-semibold  text-ink">' + weeklyAvg + '</div><div class="text-xs text-mute mt-1">Avg min/day</div></div></div><div class="py-2"><div class="flex items-center justify-between mb-2"><span class="text-sm text-body">Active Days</span><span class="text-sm text-ink font-medium">' + weeklyActiveDays + '/7</span></div><div class="h-2 bg-canvas-subtle rounded-full overflow-hidden"><div class="h-full bg-primary rounded-full transition-all duration-500" style="width:' + weeklyConsistencyPct + '%"></div></div></div><div class="flex items-center justify-between py-2"><span class="text-sm text-body">Consistency</span><span class="text-sm font-medium text-ink">' + weeklyConsistencyPct + '%</span></div><div class="pt-2"><div class="flex items-end gap-1 h-16">';
    var dayNames = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
    for (var wi = 0; wi < 7; wi++) {
      var wd = weekDays[wi];
      var pct = wd.entry ? Math.min(100, Math.round((wd.entry.actualMinutes / plan.target) * 100)) : 0;
      html += '<div class="flex-1 flex flex-col items-center gap-1"><div class="w-full bg-canvas-subtle rounded-sm overflow-hidden" style="height:40px"><div class="w-full bg-primary rounded-sm transition-all duration-500" style="height:' + pct + '%"></div></div><span class="text-xs text-mute">' + dayNames[wi] + '</span></div>';
    }
    html += '</div></div></div>';
    }

    // Plan Progress (with target hits + best period + resistance sets)
    html += '<div class="bg-canvas rounded-md p-6 md:p-8 space-y-5 mb-6 border border-hairline"><div class="flex items-center gap-2"><span class="text-xs text-mute">Your journey so far</span></div><div class="grid grid-cols-3 gap-3 py-3 border-b border-hairline"><div class="text-center"><div class="text-xl font-semibold  text-ink">' + monthlyTotal + '</div><div class="text-xs text-mute mt-1">Total min</div></div><div class="text-center"><div class="text-xl font-semibold  text-ink">' + monthlyActiveDays + '</div><div class="text-xs text-mute mt-1">Active days</div></div><div class="text-center"><div class="text-xl font-semibold  text-ink">Day ' + dayNum + '</div><div class="text-xs text-mute mt-1">of 30</div></div></div><div class="py-2 space-y-3"><div class="flex items-center justify-between"><span class="text-sm text-body">Plan Progress</span><span class="text-sm text-ink font-medium">' + Math.round((dayNum / 30) * 100) + '%</span></div><div class="h-2 bg-canvas-subtle rounded-full overflow-hidden"><div class="h-full bg-primary rounded-full transition-all duration-500" style="width:' + Math.round((dayNum / 30) * 100) + '%"></div></div></div><div class="pt-3 border-t border-hairline space-y-2"><div class="flex items-center justify-between"><span class="text-sm text-body">Target hit</span><span class="text-sm text-ink font-medium">' + targetHits + ' / ' + Math.min(planDays, dayNum) + ' days</span></div><div class="flex items-center justify-between"><span class="text-sm text-body">Best consistency period</span><span class="text-sm text-ink font-medium">' + bestPeriod + ' day' + (bestPeriod !== 1 ? 's' : '') + '</span></div>' + (totalSets > 0 ? '<div class="flex items-center justify-between"><span class="text-sm text-body">Total resistance sets</span><span class="text-sm text-ink font-medium">' + totalSets + '</span></div>' : '') + '</div></div>';

    // Consistency Score
    html += '<div class="bg-canvas rounded-md p-6 md:p-8 space-y-5 mb-6 border border-hairline"><div class="flex items-center gap-2"><span class="text-xs text-mute">Your consistency</span></div><div class="text-center py-4"><div class="text-4xl font-semibold  text-ink mb-1">' + consistencyScore + '%</div><p class="text-sm text-body">Based on active days and daily participation</p></div><div class="h-2 bg-canvas-subtle rounded-full overflow-hidden"><div class="h-full bg-primary rounded-full transition-all duration-500" style="width:' + consistencyScore + '%"></div></div><div class="bg-canvas-soft rounded-md p-3 text-center mt-2">' + (consistencyScore >= 80 ? '<p class="text-sm text-body leading-relaxed">Great consistency. Keep showing up.</p>' : consistencyScore >= 50 ? '<p class="text-sm text-body leading-relaxed">You are building momentum. Consistency grows over time.</p>' : '<p class="text-sm text-body leading-relaxed">Every day is a new opportunity. Start small and stay consistent.</p>') + '</div></div>';

    // Compare
    if (showCompare && prevStats) {
      html += '<div class="bg-canvas rounded-md p-6 md:p-8 space-y-5 mb-6 border border-hairline"><div class="flex items-center gap-2"><span class="text-xs text-mute">Previous 30 Days</span></div><div class="grid grid-cols-3 gap-3 py-3 border-b border-hairline"><div class="text-center"><div class="text-xl font-semibold  text-mute">' + prevStats.target + '</div><div class="text-xs text-mute mt-1">Target</div></div><div class="text-center"><div class="text-xl font-semibold  text-mute">' + prevStats.minimum + '</div><div class="text-xs text-mute mt-1">Minimum</div></div><div class="text-center"><div class="text-xl font-semibold  text-mute">' + prevStats.maximum + '</div><div class="text-xs text-mute mt-1">Maximum</div></div></div><div class="py-2 space-y-3"><div class="flex items-center justify-between"><span class="text-sm text-body">Total Minutes</span><span class="text-sm text-ink font-medium">' + prevStats.totalMinutes + '</span></div><div class="flex items-center justify-between"><span class="text-sm text-body">Active Days</span><span class="text-sm text-ink font-medium">' + prevStats.activeDays + '/' + prevStats.days + '</span></div><div class="flex items-center justify-between"><span class="text-sm text-body">Consistency</span><span class="text-sm text-ink font-medium">' + prevStats.consistencyPct + '%</span></div></div><div class="h-2 bg-canvas-subtle rounded-full overflow-hidden"><div class="h-full bg-mute/50 rounded-full transition-all duration-500" style="width:' + prevStats.consistencyPct + '%"></div></div></div>';
    }

    // Recent Activity (with notes + edit)
    var recentEntries = Object.entries(checkIns).filter(function (r) { return r[0] !== todayStr; }).sort(function (a, b) { return b[0].localeCompare(a[0]); }).slice(0, 10);
    if (recentEntries.length > 0) {
      html += '<div class="bg-canvas rounded-md p-6 md:p-8 space-y-4 mt-6 border border-hairline"><h2 class="text-lg font-semibold  text-ink">Recent Activity</h2>';
      for (var ei = 0; ei < recentEntries.length; ei++) {
        var date = recentEntries[ei][0], entry = recentEntries[ei][1];
        html += '<div class="py-2 border-b border-hairline last:border-b-0" data-date="' + date + '"><div class="flex items-center justify-between"><span class="text-sm text-body">' + formatDate(date) + '</span><div class="flex items-center gap-2"><span class="text-sm text-ink font-medium entry-mins">' + entry.actualMinutes + ' min</span><button class="edit-entry text-[10px] text-mute hover:text-ink transition-colors" data-date="' + date + '">edit</button></div></div>' + (entry.note ? '<p class="text-xs text-mute mt-1 leading-relaxed entry-note">' + escapeHtml(entry.note) + '</p>' : '') + '</div>';
      }
      html += '</div>';
    }

    // Adjustment History
    var adjustments = getAdjustments();
    if (adjustments.length > 0) {
      html += '<div class="bg-canvas rounded-md p-6 md:p-8 space-y-4 mt-6 border border-hairline"><h2 class="text-lg font-semibold  text-ink">Plan Adjustments</h2>';
      for (var ai = adjustments.length - 1; ai >= 0; ai--) {
        var adj = adjustments[ai];
        var arrow = adj.direction === 'increased' ? '\u2191' : '\u2193';
        var color = adj.direction === 'increased' ? 'text-success' : 'text-mute';
        html += '<div class="flex items-center justify-between py-2 border-b border-hairline last:border-b-0"><span class="text-sm text-body">' + formatDate(adj.date) + '</span><span class="text-sm text-ink font-medium ' + color + '">' + adj.previousTarget + ' ' + arrow + ' ' + adj.newTarget + ' min</span></div>';
      }
      html += '</div>';
    }

    // Export button
    html += '<p class="text-xs text-mute text-center mt-8">Your data is yours. Download it anytime.</p>';
    html += '<div class="flex items-center justify-center mt-2 gap-3"><button id="btn-export" class="inline-flex items-center h-9 px-4 bg-canvas text-ink text-xs font-medium rounded-full no-underline border border-hairline transition-colors hover:bg-canvas-soft">Export Data</button></div>';

    // Weekly review
    var today = new Date(); var dayOfWeek = today.getDay();
    var weekKey = 'habit-build-weekly-review-' + getDateString(getWeekStart());
    var hasWeeklyReview = false;
    try { hasWeeklyReview = localStorage.getItem(weekKey) !== null; } catch {}
    if (dayOfWeek === 0 && !hasWeeklyReview && monthlyActiveDays > 0) {
      html += '<div class="bg-canvas-soft rounded-md p-5 mt-6 border border-hairline"><p class="text-sm text-body leading-relaxed mb-3 font-medium">Weekly check-in: How did this week feel?</p><div class="flex gap-2 mb-3"><button data-review="great" class="review-btn inline-flex items-center h-8 px-3 bg-canvas text-ink text-xs font-medium rounded-full border border-hairline transition-colors hover:bg-canvas-soft">Great</button><button data-review="okay" class="review-btn inline-flex items-center h-8 px-3 bg-canvas text-ink text-xs font-medium rounded-full border border-hairline transition-colors hover:bg-canvas-soft">Okay</button><button data-review="hard" class="review-btn inline-flex items-center h-8 px-3 bg-canvas text-ink text-xs font-medium rounded-full border border-hairline transition-colors hover:bg-canvas-soft">Hard</button></div><textarea id="weekly-note" placeholder="What worked? What was difficult? (optional)" class="w-full text-sm text-ink bg-canvas rounded-md px-3 py-2 border border-hairline resize-none focus:outline-none focus:border-ink/40 transition-colors" rows="2"></textarea></div>';
    }

    app.innerHTML = html;

    // Event listeners
    document.querySelectorAll('.review-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var val = btn.getAttribute('data-review');
        var noteEl = document.getElementById('weekly-note');
        var note = noteEl ? noteEl.value : '';
        try { localStorage.setItem(weekKey, JSON.stringify({ rating: val, note: note, date: getTodayString() })); } catch {}
        document.querySelectorAll('.review-btn').forEach(function (b) { b.classList.remove('bg-primary', 'text-on-primary', 'border-primary'); });
        btn.classList.add('bg-primary', 'text-on-primary', 'border-primary');
      });
    });

    var toggleCmp = document.getElementById('toggle-compare');
    if (toggleCmp) {
      toggleCmp.addEventListener('change', function () { showCompare = toggleCmp.checked; renderProgress(); });
    }

    document.querySelectorAll('.edit-entry').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var date = btn.getAttribute('data-date');
        var container = btn.closest('[data-date]');
        var entry = checkIns[date];
        if (!entry || !container) return;
        container.innerHTML = '<div class="flex items-center gap-2 mt-1"><input id="edit-min-' + date + '" type="number" min="0" max="480" value="' + entry.actualMinutes + '" class="w-20 h-8 px-2 bg-canvas text-ink text-sm border border-hairline rounded-sm outline-none focus:border-ink tabular-nums" /><span class="text-xs text-mute">min</span><button class="save-edit inline-flex items-center h-7 px-3 bg-primary text-on-primary text-xs font-medium rounded-full" data-date="' + date + '">Save</button><button class="cancel-edit inline-flex items-center h-7 px-3 bg-canvas text-ink text-xs font-medium rounded-full border border-hairline" data-date="' + date + '">Cancel</button></div><textarea id="edit-note-' + date + '" class="w-full text-xs text-ink bg-canvas rounded-md px-2 py-1.5 border border-hairline resize-none focus:outline-none focus:border-ink/40 transition-colors mt-2" rows="2">' + escapeHtml(entry.note || '') + '</textarea>';
        document.getElementById('edit-min-' + date)?.focus();
      });
    });

    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.save-edit');
      if (btn) {
        var date = btn.getAttribute('data-date');
        var minInput = document.getElementById('edit-min-' + date);
        var noteInput = document.getElementById('edit-note-' + date);
        var mins = parseInt(minInput ? minInput.value : '0', 10);
        if (isNaN(mins) || mins < 0) mins = 0;
        var note = noteInput ? noteInput.value : '';
        var ci = getSavedCheckIns();
        if (ci[date]) {
          ci[date].actualMinutes = mins;
          ci[date].note = note;
          try { localStorage.setItem(CHECKINS_KEY, JSON.stringify(ci)); } catch {}
        }
        renderProgress();
      }
      var cancelBtn = e.target.closest('.cancel-edit');
      if (cancelBtn) renderProgress();
    });

    document.getElementById('btn-export')?.addEventListener('click', function () {
      var data = exportAllData();
      var blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url; a.download = 'habit-build-backup-' + getTodayString() + '.json';
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });
  }

  renderProgress();
</script>
