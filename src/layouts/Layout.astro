---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Habit Build — Build habits that stick.', description = 'A gentle, sustainable approach to building habits. Focus on consistency, not intensity.' } = Astro.props;
---

